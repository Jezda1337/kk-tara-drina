---
import Layout from "../../layouts/Layout.astro";
import { actions } from "astro:actions";
---

<Layout title="Contact — KK Tara Drina">
  <section class="page-hero">
    <img
      src="https://picsum.photos/seed/contact1/1920/600"
      alt=""
      class="page-hero__bg"
    />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Get in touch</span>
      <h1 class="page-title">Contact</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg
        viewBox="0 0 1440 70"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"
        ></path>
      </svg>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="split-layout">
        <div class="split-layout__text">
          <span class="eyebrow">Information</span>
          <h2 class="section-title">Contact & reservations</h2>
          <ul class="contact-info-list" style="margin-top:1.5rem;">
            <li class="contact-info-item">
              <span class="contact-info-item__icon">
                <svg
                  width="14"
                  height="14"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                  ></path></svg
                >
              </span>
              <div>
                <p class="contact-info-item__label">Address (base)</p>
                <p class="contact-info-item__value">
                  Rača Picnic Area, Bajina Bašta, Serbia
                </p>
              </div>
            </li>
            <li class="contact-info-item">
              <span class="contact-info-item__icon">
                <svg
                  width="14"
                  height="14"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
                  ></path></svg
                >
              </span>
              <div>
                <p class="contact-info-item__label">Phone / WhatsApp / Viber</p>
                <p class="contact-info-item__value">
                  <a href="tel:+381648969466">+381 64 896 9466</a><br />
                  <a href="tel:+381654190939">+381 65 419 0939</a>
                </p>
              </div>
            </li>
            <li class="contact-info-item">
              <span class="contact-info-item__icon">
                <svg
                  width="14"
                  height="14"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                  ></path></svg
                >
              </span>
              <div>
                <p class="contact-info-item__label">Email</p>
                <p class="contact-info-item__value">
                  <a href="mailto:info@kajakdrina.rs">info@kajakdrina.rs</a>
                </p>
              </div>
            </li>
            <li class="contact-info-item">
              <span class="contact-info-item__icon">
                <svg
                  width="14"
                  height="14"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
                  ></path></svg
                >
              </span>
              <div>
                <p class="contact-info-item__label">Season</p>
                <p class="contact-info-item__value">May – October</p>
              </div>
            </li>
          </ul>
        </div>

        <div>
          <span class="eyebrow">Send an enquiry</span>
          <h2 class="section-title">Contact form</h2>
          <p
            style="font-size:0.875rem; color:#4a6258; margin:0.5rem 0 1.5rem; line-height:1.6;"
          >
            Fill in the form and we'll get back to you within 24 hours.
          </p>
          <form style="margin-top:1.5rem;" method="POST" action={actions.send}>
            <div class="form-group">
              <label class="form-label" for="ime-prezime">Full name</label>
              <input
                id="ime-prezime"
                type="text"
                placeholder="Your full name"
                class="form-input"
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="telefon">Phone number</label>
              <input
                id="telefon"
                type="tel"
                placeholder="+381 6x xxx xxxx"
                class="form-input"
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="usluga"
                >What are you interested in?</label
              >
              <select id="usluga" class="form-select">
                <option value="">Select a service</option>
                <option value="tura1">Tour 1 — Perućac → Rača</option>
                <option value="tura2">Tour 2 — Rača → Rogačica</option>
                <option value="skola">Kayak school</option>
                <option value="rekreacija">Recreational paddling</option>
                <option value="teambuilding">Team Building</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="datum">Planned date</label>
              <input id="datum" type="date" class="form-input" />
            </div>
            <div class="form-group">
              <label class="form-label" for="osobe">Number of people</label>
              <input
                id="osobe"
                type="number"
                min="1"
                placeholder="e.g. 4"
                class="form-input"
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="poruka">Message (optional)</label>
              <textarea
                id="poruka"
                rows="4"
                placeholder="Additional notes, questions..."
                class="form-textarea"></textarea>
            </div>
            <button
              type="submit"
              class="btn btn--primary btn--large"
              style="width:100%; justify-content:center;"
            >
              Send enquiry
              <svg
                class="btn__arrow"
                fill="none"
                viewBox="0 0 16 16"
                aria-hidden="true"
                ><path
                  d="M3 8h10M9 4l4 4-4 4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path></svg
              >
            </button>
          </form>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg
        viewBox="0 0 1440 80"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#0a1a12"
        ></path>
      </svg>
    </div>
  </section>
</Layout>
