---
import TourLayout from "../../layouts/TourLayout.astro";

const gallerySlides = [
  { src: "https://picsum.photos/seed/drina_a1/1200/800", location: "Brana Perućac", caption: "Lorem ipsum dolor sit amet consectetur adipiscing elit" },
  { src: "https://picsum.photos/seed/drina_a2/1200/800", location: "Drina — gornji tok", caption: "Ut enim ad minim veniam quis nostrud exercitation ullamco" },
  { src: "https://picsum.photos/seed/drina_a3/1200/800", location: "Bajina Bašta", caption: "Duis aute irure dolor in reprehenderit in voluptate" },
  { src: "https://picsum.photos/seed/drina_a4/1200/800", location: "Mirni tok", caption: "Excepteur sint occaecat cupidatat non proident sunt" },
  { src: "https://picsum.photos/seed/drina_a5/1200/800", location: "Plaža Rača", caption: "Nemo enim ipsam voluptatem quia voluptas sit aspernatur" },
  { src: "https://picsum.photos/seed/drina_a6/1200/800", location: "Drina", caption: "Sed ut perspiciatis unde omnis iste natus error sit" },
];
---

<TourLayout
  title="Perućac → Rača"
  subtitle="Tura na Drini — kajak za sve uzraste"
  heroSeed="drinariver"
  distance="~15 km"
  duration="~3 sata"
  difficulty="Laka — za početnike"
  season="Maj – Oktobar"
  contactHref="/kontakt"
  contactLabel="Rezervišite turu"
  gallerySlides={gallerySlides}
  equipmentLabel="Oprema uključena"
>
  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">O turi</h2>
    <div class="space-y-4 leading-relaxed text-slate-600">
      <p>
        Tura kreće ispod brane Perućac u Bajnoj Bašti i vodi niz mirni tok Drine do plaže Rača. Ruta je idealna za
        porodice, grupe prijatelja i sve koji žele da uživaju u prirodi sa kajakom — bez ikavog prethodnog
        iskustva.
      </p>
      <p>
        Koristimo prostrane rekreativne kajake koji su stabilni i laki za upravljanje. Iskusni vodič
        prati grupu tokom cele rute i brine se o bezbednosti. Tok Drine u ovom delu je miran i bez
        brzaka.
      </p>
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed ut perspiciatis unde omnis iste
        natus error sit voluptatem accusantium doloremque laudantium, totam rem aperiam.
      </p>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">Zaustavljanja na ruti</h2>
    <div class="space-y-4">
      {
        [
          { place: "Brana Perućac", time: "09:00", text: "Polazak sa pristaništa ispod brane. Kratki uvod u upravljanje kajakom — max 15 minuta." },
          { place: "Bajina Bašta", time: "10:00", text: "Prolazak pored grada. Lorem ipsum dolor sit amet consectetur adipiscing elit ut enim." },
          { place: "Odmor na vodi", time: "11:00", text: "Pauza usred reke — plivanje, fotografisanje, odmor. Duis aute irure dolor in reprehenderit." },
          { place: "Plaža Rača", time: "12:00", text: "Dolazak na plažu Rača. Kupanje i ručak na obali pre povratka." },
        ].map((stop) => (
          <div class="flex gap-4 rounded-xl border border-slate-100 p-5">
            <div class="flex-shrink-0">
              <span class="block text-xs font-bold text-teal-600">{stop.time}</span>
            </div>
            <div>
              <h3 class="mb-1 font-bold text-slate-900">{stop.place}</h3>
              <p class="text-sm text-slate-600">{stop.text}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">Šta je uključeno</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {
        [
          { included: true, text: "Rekreativni kajak i veslo" },
          { included: true, text: "Prsluk za spasavanje" },
          { included: true, text: "Iskusni vodič" },
          { included: true, text: "Uvod za početnike (15 min)" },
          { included: true, text: "Prevoz do polazišta" },
          { included: true, text: "Osiguranje" },
          { included: false, text: "Hrana i piće" },
          { included: false, text: "Lični rashodi" },
        ].map((item) => (
          <div class="flex items-center gap-3 text-sm">
            <span class:list={["flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full text-xs font-bold", item.included ? "bg-teal-100 text-teal-700" : "bg-red-50 text-red-400"]}>
              {item.included ? "✓" : "✗"}
            </span>
            <span class:list={[item.included ? "text-slate-700" : "text-slate-400"]}>{item.text}</span>
          </div>
        ))
      }
    </div>
  </section>
</TourLayout>
