---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kontakt">

  <section class="page-hero">
    <img src="https://picsum.photos/seed/contact1/1920/600" alt="" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Stupite u kontakt</span>
      <h1 class="page-title">Kontakt</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="split-layout">

        <!-- Info -->
        <div class="split-layout__text">
          <span class="eyebrow">Informacije</span>
          <h2 class="section-title">Kako nas kontaktirati</h2>
          <ul class="contact-info-list" style="margin-top:1.5rem;">
            <li class="contact-info-item">
              <span class="contact-info-item__icon">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              </span>
              <div>
                <p class="contact-info-item__label">Adresa</p>
                <p class="contact-info-item__value">Lorem ipsum bb, Srbija</p>
              </div>
            </li>
            <li class="contact-info-item">
              <span class="contact-info-item__icon">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              </span>
              <div>
                <p class="contact-info-item__label">Telefon</p>
                <p class="contact-info-item__value"><a href="tel:+381xxxxxxxx">+381 xx xxx xxxx</a></p>
              </div>
            </li>
            <li class="contact-info-item">
              <span class="contact-info-item__icon">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              </span>
              <div>
                <p class="contact-info-item__label">Email</p>
                <p class="contact-info-item__value"><a href="mailto:info@kktaradrina.rs">info@kktaradrina.rs</a></p>
              </div>
            </li>
            <li class="contact-info-item">
              <span class="contact-info-item__icon">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </span>
              <div>
                <p class="contact-info-item__label">Radno vreme</p>
                <p class="contact-info-item__value">Pon–Pet: 09:00–17:00<br/>Sub: 10:00–14:00</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Form -->
        <div>
          <span class="eyebrow">Poruka</span>
          <h2 class="section-title">Pišite nam</h2>
          <form style="margin-top:1.5rem;">
            <div class="form-grid-2">
              <div class="form-group">
                <label class="form-label" for="ime">Ime</label>
                <input id="ime" type="text" placeholder="Vaše ime" class="form-input" />
              </div>
              <div class="form-group">
                <label class="form-label" for="prezime">Prezime</label>
                <input id="prezime" type="text" placeholder="Vaše prezime" class="form-input" />
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="email">Email</label>
              <input id="email" type="email" placeholder="vas@email.com" class="form-input" />
            </div>
            <div class="form-group">
              <label class="form-label" for="tura">Tura (opciono)</label>
              <select id="tura" class="form-select">
                <option value="">Odaberite turu</option>
                <option value="tara-drina">Perućac → Rača</option>
                <option value="drina-sava">Rača → Rogačica</option>
                <option value="skola">Škola kajaka</option>
                <option value="ostalo">Ostalo</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="poruka">Poruka</label>
              <textarea id="poruka" rows="5" placeholder="Vaša poruka..." class="form-textarea"></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--large" style="width:100%; justify-content:center;">
              Pošalji poruku
              <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

</Layout>
