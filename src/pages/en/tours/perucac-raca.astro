---
import TourLayout from "../../../layouts/TourLayout.astro";

const gallerySlides = [
  {
    src: "https://picsum.photos/seed/drina_a1/1200/800",
    location: "Perućac Dam",
    caption: "Starting point — turquoise Drina just below the Perućac dam",
  },
  {
    src: "https://picsum.photos/seed/drina_a2/1200/800",
    location: "Vrelo River — 'The Year'",
    caption: "The Vrelo waterfall (365 m) flowing directly into the Drina",
  },
  {
    src: "https://picsum.photos/seed/drina_a3/1200/800",
    location: "Turquoise Drina",
    caption:
      "The river's signature colour — refreshing even on the hottest days",
  },
  {
    src: "https://picsum.photos/seed/drina_a4/1200/800",
    location: "Untouched nature",
    caption: "Forests and cliffs framing the Drina through the Podrinje region",
  },
  {
    src: "https://picsum.photos/seed/drina_a5/1200/800",
    location: "Rača Picnic Area",
    caption: "Tour destination — sandy beach perfect for a rest and a swim",
  },
  {
    src: "https://picsum.photos/seed/drina_a6/1200/800",
    location: "Drina",
    caption: "Every metre of river reveals beauty hidden from those on shore",
  },
];
---

<TourLayout
  title="Perućac → Rača"
  subtitle="Tour 1 — Kayak tour on the Drina"
  heroSeed="drinariver"
  distance="~15 km"
  duration="~2.5 hours"
  difficulty="Easy — ideal for beginners"
  season="May – October"
  contactHref="/en/contact"
  contactLabel="Book this tour"
  gallerySlides={gallerySlides}
  equipmentLabel="Equipment included"
>
  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">About the tour</h2>
    <div class="space-y-4 leading-relaxed text-slate-600">
      <p>
        This tour is the perfect introduction to the world of kayaking. The
        descent starts just below the Perućac dam, where the Drina takes on its
        signature turquoise colour and a freshness that invigorates even on the
        hottest summer days.
      </p>
      <p>
        Right at the beginning we pass the mouth of the Vrelo river, known as <strong
          >"The Year"</strong
        >
        because it is exactly 365 metres long. The view of its waterfall flowing directly
        into the Drina — seen from the kayak — is a sight you won't forget and a perfect
        shot for your first photos.
      </p>
      <p>
        The Drina is calm and pleasant along this stretch — no rapids or
        obstacles. We use spacious recreational kayaks that are stable and easy
        to handle. An experienced guide accompanies the group throughout the
        route, looking after safety while sharing knowledge about the nature and
        history of this region.
      </p>
    </div>

    <div
      class="mt-6 inline-flex items-center gap-3 rounded-xl border border-emerald-100 bg-emerald-50 px-5 py-3"
    >
      <span
        class="text-2xl font-bold text-emerald-700"
        style="font-family:'Barlow Condensed',sans-serif;">3,600 RSD</span
      >
      <span class="text-sm text-slate-500">per person · equipment included</span
      >
    </div>
  </section>

  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">Route & stops</h2>
    <div class="space-y-4">
      {
        [
          {
            place: "Perućac Dam",
            time: "Departure",
            text: "Start at the landing just below the dam. A short 15-minute intro to kayak handling — then the adventure begins.",
          },
          {
            place: "Vrelo River — 'The Year'",
            time: "On the water",
            text: "Pass the mouth of the Vrelo river (365 m). A direct view of the waterfall as it meets the Drina — an unforgettable sight and a great photo stop.",
          },
          {
            place: "Calm Drina",
            time: "On the water",
            text: "Paddling through the unspoilt nature of Podrinje. The only sounds are paddle strokes and birdsong from the forests lining the banks.",
          },
          {
            place: "Rača Picnic Area",
            time: "Finish",
            text: "Arrival at Rača picnic area. Refreshments, a swim, and time to share impressions from the water. Organised transport back to base.",
          },
        ].map((stop) => (
          <div class="flex gap-4 rounded-xl border border-slate-100 p-5">
            <div class="flex-shrink-0">
              <span class="block text-xs font-bold text-teal-600">
                {stop.time}
              </span>
            </div>
            <div>
              <h3 class="mb-1 font-bold text-slate-900">{stop.place}</h3>
              <p class="text-sm text-slate-600">{stop.text}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">What's included</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {
        [
          { included: true, text: "Recreational kayak and paddle" },
          { included: true, text: "Life jacket" },
          { included: true, text: "Licensed guide" },
          { included: true, text: "Beginner intro (15 min)" },
          { included: true, text: "Organised transport from base" },
          { included: true, text: "Changing room and storage space" },
          { included: true, text: "Refreshments at the destination" },
          { included: false, text: "Food and personal expenses" },
        ].map((item) => (
          <div class="flex items-center gap-3 text-sm">
            <span
              class:list={[
                "flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full text-xs font-bold",
                item.included
                  ? "bg-teal-100 text-teal-700"
                  : "bg-red-50 text-red-400",
              ]}
            >
              {item.included ? "✓" : "✗"}
            </span>
            <span
              class:list={[item.included ? "text-slate-700" : "text-slate-400"]}
            >
              {item.text}
            </span>
          </div>
        ))
      }
    </div>
  </section>
</TourLayout>
