---
import Layout from "../../layouts/Layout.astro";

const courses = [
  {
    num: "01",
    eyebrow: "Beginner level",
    title: "Beginners' kayak school",
    duration: "5 sessions + final descent",
    price: "6,000 RSD",
    desc: "We run a beginners' kayak school on the Drina, at Rača picnic area. Over five days, a kayak instructor will introduce you to the basics of safe paddling on calm and easy whitewater.",
    features: [
      "Basic paddling equipment",
      "Water safety fundamentals",
      "Proper paddle grip & technique",
      "Kayak steering basics",
      "Entering current & eddies",
      "Final river descent",
    ],
  },
  {
    num: "02",
    eyebrow: "Advanced level",
    title: "Advanced kayak school",
    duration: "4 sessions",
    price: "5,000 RSD",
    desc: "Designed for those who already paddle and want to improve. Special focus on more demanding moves, precise entries into currents and eddies, and stronger kayak edging.",
    features: [
      "Advanced paddling techniques",
      "Precise current entries",
      "Kayak edging & lean",
      "Efficient use of river flow",
      "Locations: Crvene vode & Bujaković rapid",
    ],
  },
  {
    num: "03",
    eyebrow: "Individual approach",
    title: "Individual kayak school",
    duration: "1 session (60 min)",
    price: "2,500 RSD",
    desc: "We tailor individual sessions to your goals, schedule and prior knowledge. You can learn paddling basics with a kayak instructor, improve existing skills, or learn the Eskimo roll.",
    features: [
      "Fully customised program",
      "Beginner or advanced techniques",
      "Skills refresher",
      "Eskimo roll",
      "Flexible scheduling",
    ],
  },
];

const skills = [
  { icon: "🚣", title: "Paddling technique", text: "Proper paddle stroke, steering in current, turning and stopping — the foundation of everything." },
  { icon: "🛟", title: "Water safety", text: "Capsize procedures, self-rescue, assisting others and basic water rescue techniques." },
  { icon: "🗺️", title: "River navigation", text: "Reading the river, assessing rapids, entering currents and eddies, route planning on whitewater." },
  { icon: "⛵", title: "Eskimo roll", text: "The technique of righting a capsized kayak without exiting — for advanced participants." },
];
---

<Layout title="Kayak School — KK Tara Drina">

  <section class="page-hero">
    <img src="https://picsum.photos/seed/school2/1920/800" alt="" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Learn to paddle</span>
      <h1 class="page-title">Kayak school</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="split-layout">
        <div class="split-layout__text">
          <span class="eyebrow">Expert-led</span>
          <h2 class="section-title">School led by a licensed coach</h2>
          <p class="body-text">
            The kayak school is led by a licensed coach, long-time Serbian national team
            representative, participant in World and European Championships and water rescue
            specialist.
          </p>
          <p class="body-text">
            All programs are carefully designed for recreational paddling, with a focus on
            safety and correct technique. The same precision and discipline needed for top
            sporting results are built into every program.
          </p>
          <p class="body-text">
            We provide all equipment for every school participant — kayak, paddle and life
            jacket. Just show up in your swimwear and good spirits.
          </p>
        </div>
        <div class="split-layout__media">
          <img src="https://picsum.photos/seed/school3/900/700" alt="Kayak school on the Drina" class="split-img" />
          <div class="split-img__accent"></div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 L1440,70 L1440,70 L0,70 Z" fill="#ffffff"/>
      </svg>
    </div>
  </section>

  <section class="section section--white">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Training levels</span>
        <h2 class="section-title">Choose your program</h2>
        <p class="section-sub">We tailor the program to your experience and goals. Contact us for information on schedules and groups.</p>
      </div>
      <div class="level-grid">
        {courses.map((c) => (
          <div class="level-card">
            <div class="level-card__num">{c.num}</div>
            <p class="level-card__eyebrow">{c.eyebrow}</p>
            <h3 class="level-card__title">{c.title}</h3>
            <p class="level-card__duration">{c.duration}</p>
            <p class="level-card__price">{c.price}</p>
            <p class="level-card__desc">{c.desc}</p>
            <ul class="level-card__features">
              {c.features.map((f) => (
                <li class="level-card__feature">
                  <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,80 C360,0 1080,80 1440,0 L1440,80 L0,80 Z" fill="#1a4a2e"/>
      </svg>
    </div>
  </section>

  <section class="section section--forest-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.12)" stroke-width="0.8" fill="none">
          <path d="M-100,430 C200,395 360,435 560,402 C760,370 920,410 1120,378 C1310,350 1420,385 1540,368"/>
          <path d="M-100,395 C215,358 378,400 580,366 C780,332 940,375 1140,340 C1330,310 1432,348 1540,330"/>
          <path d="M-100,360 C232,320 395,365 600,328 C800,295 960,338 1160,302 C1350,270 1440,310 1540,292"/>
          <path d="M-100,325 C250,282 412,328 620,290 C820,255 980,300 1180,262 C1370,228 1448,270 1540,252"/>
        </g>
      </svg>
    </div>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow eyebrow--light">Curriculum</span>
        <h2 class="section-title section-title--light">What you'll learn</h2>
      </div>
      <div class="skill-grid">
        {skills.map((s) => (
          <div class="skill-card" style="background:rgba(255,255,255,0.05);">
            <div class="skill-card__icon">{s.icon}</div>
            <h3 class="skill-card__title" style="color:#fff;">{s.title}</h3>
            <p class="skill-card__text" style="color:rgba(255,255,255,0.45);">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section class="section section--cta">
    <div class="container">
      <div class="cta-block">
        <span class="eyebrow">Interested?</span>
        <h2 class="cta-title">Sign up today</h2>
        <p class="cta-sub">Contact us for information on schedules and groups. The school is held at Rača picnic area in Bajina Bašta.</p>
        <a href="/en/contact" class="btn btn--primary btn--large">
          Contact us
          <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

</Layout>

<style>
  .level-card__price {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #2a7a54;
    margin-bottom: 0.75rem;
  }
</style>
