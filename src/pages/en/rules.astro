---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Rules — KK Tara Drina">
  <!-- Page hero -->
  <section class="page-hero">
    <img
      src="https://picsum.photos/seed/safety1/1920/800"
      alt=""
      class="page-hero__bg"
    />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Your safety</span>
      <h1 class="page-title">Rules</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg
        viewBox="0 0 1440 70"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"
        ></path>
      </svg>
    </div>
  </section>

  <!-- Rules section -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:52rem; margin-inline:auto;">
        <div class="rules-intro">
          <h2 class="section-title">Safety and Conduct Rules</h2>
          <p
            class="body-text"
            style="font-size:1.1rem; color:#0a1a12; margin-bottom:2rem;"
          >
            Your safety is our absolute priority. For every tour and training to
            proceed smoothly, all participants in the association's activities
            must comply with the following rules:
          </p>
        </div>

        <div class="rules-grid">
          <div class="rule-card">
            <h3 class="rule-card__title">Safety Equipment</h3>
            <p class="rule-card__text">
              Wearing a life jacket is mandatory during all water activities.
              Equipment must be in good condition and proper size.
            </p>
          </div>

          <div class="rule-card">
            <h3 class="rule-card__title">Prohibited Substances</h3>
            <p class="rule-card__text">
              Consumption of alcohol and other psychoactive substances before
              and during activities is strictly prohibited. This rule is
              enforced for safety reasons.
            </p>
          </div>

          <div class="rule-card">
            <h3 class="rule-card__title">Health & Liability</h3>
            <p class="rule-card__text">
              Each adult participant signs a liability waiver. For minors, a
              parent or guardian must sign the waiver.
            </p>
          </div>

          <div class="rule-card">
            <h3 class="rule-card__title">Conduct on Water</h3>
            <p class="rule-card__text">
              Follow your guide's instructions at all times. Guides are trained
              and licensed to maintain group safety and their decisions are
              final.
            </p>
          </div>

          <div class="rule-card">
            <h3 class="rule-card__title">Equipment Care</h3>
            <p class="rule-card__text">
              Intentional damage or loss of equipment due to negligence will be
              subject to replacement charges. Please care for the equipment
              entrusted to you.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Additional guidelines -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:56rem; margin-inline:auto;">
        <div
          class="section-header"
          style="text-align:center; margin-bottom:3rem;"
        >
          <span class="eyebrow">Practical Tips</span>
          <h2 class="section-title">Additional Recommendations</h2>
        </div>

        <div class="feature-grid">
          <div class="feature-item">
            <span class="feature-item__bar"></span>
            <div>
              <h3 class="feature-item__title">Before the Activity</h3>
              <p class="feature-item__text">
                Inform your guide of any health concerns, arrive in good
                physical condition, check weather conditions and wear
                appropriate sun protection.
              </p>
            </div>
          </div>

          <div class="feature-item">
            <span class="feature-item__bar"></span>
            <div>
              <h3 class="feature-item__title">During the Activity</h3>
              <p class="feature-item__text">
                Never leave the group without permission, always wear your life
                jacket, keep an eye on other members and notify your guide if
                unwell.
              </p>
            </div>
          </div>

          <div class="feature-item">
            <span class="feature-item__bar"></span>
            <div>
              <h3 class="feature-item__title">After the Activity</h3>
              <p class="feature-item__text">
                Return all equipment in good condition, report any equipment
                damage, follow guide instructions for storage and share your
                feedback.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA section -->
  <section class="section section--dark-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg
        viewBox="0 0 1440 500"
        preserveAspectRatio="xMidYMid slice"
        xmlns="http://www.w3.org/2000/svg"
      >
        <g stroke="rgba(74,186,130,0.1)" stroke-width="0.8" fill="none">
          <path
            d="M-100,440 C200,405 360,448 560,415 C760,382 920,422 1120,390 C1310,362 1420,398 1540,380"
          ></path>
          <path
            d="M-100,405 C215,368 378,412 580,378 C780,344 940,388 1140,352 C1330,322 1432,362 1540,345"
          ></path>
          <path
            d="M-100,370 C232,330 395,375 600,338 C800,305 960,350 1160,312 C1350,280 1440,322 1540,305"
          ></path>
          <path
            d="M-100,335 C250,292 412,338 620,298 C820,262 980,310 1180,272 C1370,238 1448,282 1540,265"
          ></path>
          <path
            d="M-100,300 C268,254 430,302 638,260 C840,222 1000,272 1200,232 C1390,198 1455,244 1540,225"
          ></path>
        </g>
      </svg>
    </div>
    <div class="container">
      <div style="max-width:52rem; margin-inline:auto; text-align:center;">
        <h2 class="section-title section-title--light">
          Ready for an Adventure?
        </h2>
        <p
          class="body-text"
          style="color:rgba(255,255,255,0.8); margin-bottom:2.5rem;"
        >
          Do you understand and accept all safety rules? Then you're ready for
          an unforgettable adventure on the Drina.
        </p>
        <a href="/en/tours/perucac-raca" class="btn btn--primary">
          View our tours
          <svg
            class="btn__arrow"
            fill="none"
            viewBox="0 0 16 16"
            aria-hidden="true"
            ><path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .rules-intro {
    margin-bottom: 3rem;
  }

  .rules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .rule-card {
    background: rgba(74, 186, 130, 0.06);
    border: 1px solid rgba(74, 186, 130, 0.15);
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }

  .rule-card:hover {
    background: rgba(74, 186, 130, 0.1);
    border-color: rgba(74, 186, 130, 0.3);
    transform: translateY(-2px);
  }

  .rule-card__title {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #0a1a12;
    margin-bottom: 0.75rem;
  }

  .rule-card__text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(10, 26, 18, 0.75);
  }

  .section--cream .feature-grid {
    background: transparent;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 640px) {
    .section--cream .feature-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1024px) {
    .section--cream .feature-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .section--cream .feature-item {
    padding: 2rem 2rem 2rem 1.25rem;
    border-bottom: none;
    border-left: 3px solid #4aba82;
  }

  .section--cream .feature-item__bar {
    display: none;
  }

  .section--cream .feature-item__title {
    color: #0a1a12;
  }

  .section--cream .feature-item__text {
    color: rgba(10, 26, 18, 0.7);
  }

  .btn--primary {
    background: #4aba82;
    color: #fff;
    border: 1px solid #4aba82;
    padding: 0.875rem 2rem;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 0.375rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .btn--primary:hover {
    background: #3a9468;
    border-color: #3a9468;
    transform: translateY(-2px);
  }

  .btn__arrow {
    width: 1rem;
    height: 1rem;
  }

  @media (max-width: 640px) {
    .rules-grid {
      grid-template-columns: 1fr;
    }

    .guideline-item__title {
      font-size: 1rem;
    }
  }
</style>
