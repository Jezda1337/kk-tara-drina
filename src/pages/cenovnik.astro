---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Cenovnik — KK Tara Drina">

  <section class="page-hero">
    <img src="https://picsum.photos/seed/pricing1/1920/600" alt="" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Transparentne cene</span>
      <h1 class="page-title">Cenovnik</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Sve u jednom mestu</span>
        <h2 class="section-title">Naše usluge i cene</h2>
        <p class="section-sub">
          Vaš jedini zadatak je da ponesete dobro raspoloženje — za sve ostalo brinemo mi.
          Sva oprema je uključena u cenu tura.
        </p>
      </div>

      <div class="pricing-table-wrap">
        <table class="pricing-table">
          <thead>
            <tr>
              <th>Usluga</th>
              <th>Opis</th>
              <th>Trajanje</th>
              <th>Cena</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="pricing-table__name">
                <a href="/ture/perucac-raca">Tura 1</a>
              </td>
              <td>Spust na relaciji Perućac – Izletište Rača</td>
              <td>~2,5h</td>
              <td class="pricing-table__price">3.600 din / osoba</td>
            </tr>
            <tr>
              <td class="pricing-table__name">
                <a href="/ture/raca-rogacica">Tura 2</a>
              </td>
              <td>Spust na relaciji Izletište Rača – Rogačica</td>
              <td>3 – 3,5h</td>
              <td class="pricing-table__price">4.000 din / osoba</td>
            </tr>
            <tr>
              <td class="pricing-table__name">
                <a href="/skola-kajaka">Škola kajaka za početnike</a>
              </td>
              <td>Obuhvata teoriju, treninge i završni spust</td>
              <td>5 časova + završni spust</td>
              <td class="pricing-table__price">6.000 din</td>
            </tr>
            <tr>
              <td class="pricing-table__name">
                <a href="/skola-kajaka">Napredna škola kajaka</a>
              </td>
              <td>Rad na tehnici i na divljoj vodi</td>
              <td>4 časa</td>
              <td class="pricing-table__price">5.000 din</td>
            </tr>
            <tr>
              <td class="pricing-table__name">
                <a href="/skola-kajaka">Individualna škola kajaka</a>
              </td>
              <td>Potpuno prilagođen termin i nivo znanja</td>
              <td>1 čas (60 min)</td>
              <td class="pricing-table__price">2.500 din</td>
            </tr>
            <tr>
              <td class="pricing-table__name">
                <a href="/rekreacija">Rekreacija – članarina</a>
              </td>
              <td>Korišćenje klupske opreme na mesečnom nivou</td>
              <td>Mesečno</td>
              <td class="pricing-table__price">3.000 din</td>
            </tr>
            <tr>
              <td class="pricing-table__name">Rentiranje opreme</td>
              <td>Kompletna oprema (kajak, veslo, prsluk)</td>
              <td>Po dogovoru</td>
              <td class="pricing-table__price">
                1h – 600 din<br/>
                2h – 1.000 din<br/>
                3h – 1.500 din<br/>
                Dnevno – 2.000 din
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="pricing-note">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
        </svg>
        <p>
          Za grupne rezervacije i posebne popuste kontaktirajte nas direktno.
          Plaćanje na licu mesta — gotovinom ili karticom.
        </p>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 L1440,70 L1440,70 L0,70 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

  <!-- Šta je uključeno -->
  <section class="section section--dark-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 400" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.1)" stroke-width="0.8" fill="none">
          <path d="M-100,360 C180,330 360,368 560,338 C760,308 920,348 1120,318 C1310,292 1420,325 1540,308"/>
          <path d="M-100,330 C192,298 372,338 578,305 C778,275 938,318 1138,285 C1328,258 1428,295 1540,278"/>
          <path d="M-100,300 C205,265 385,308 598,272 C798,240 958,285 1158,250 C1348,222 1432,265 1540,248"/>
          <path d="M-100,270 C220,232 400,278 618,240 C818,205 978,252 1178,215 C1368,185 1438,235 1540,215"/>
          <path d="M-100,240 C235,198 415,248 638,208 C838,172 998,222 1200,182 C1390,148 1445,205 1540,182"/>
        </g>
      </svg>
    </div>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow eyebrow--light">Svaka tura uključuje</span>
        <h2 class="section-title section-title--light">Sve za nezaboravno iskustvo</h2>
      </div>
      <div class="feature-grid">
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Stručna podrška</h3>
            <p class="feature-item__text">Iskusni, licencirani vodiči koji se brinu o vašoj bezbednosti i prenose znanje o reci.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Kompletna oprema</h3>
            <p class="feature-item__text">Pouzdani kajaci, lagana vesla i sigurnosna oprema prilagođena vašoj veličini.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Organizovan prevoz</h3>
            <p class="feature-item__text">Obezbeđujemo organizovan prevoz od našeg centra do polazišta i nazad.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Prostor za presvlačenje</h3>
            <p class="feature-item__text">U našoj bazi obezbeđeno je sigurno mesto za odlaganje ličnih stvari i presvlačenje.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Osveženje na cilju</h3>
            <p class="feature-item__text">Na odredištu vas čeka osveženje koje će vam povratiti energiju dok sabiramo utiske.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Bezbednost na prvom mestu</h3>
            <p class="feature-item__text">Svi učesnici dobijaju prsluk za spasavanje. Bezbednost je naš apsolutni prioritet.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section class="section section--cta">
    <div class="container">
      <div class="cta-block">
        <span class="eyebrow">Rezervišite mesto</span>
        <h2 class="cta-title">Pošaljite nam upit</h2>
        <p class="cta-sub">
          Kontaktirajte nas telefonom, WhatsApp-om ili popunite formu na kontakt stranici.
          Odgovaramo u roku od 24 sata.
        </p>
        <div style="display:flex; gap:1rem; flex-wrap:wrap; justify-content:center;">
          <a href="/kontakt" class="btn btn--primary btn--large">
            Pošalji upit
            <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="tel:+381648969466" class="btn btn--outline btn--large">
            Pozovite nas
          </a>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

</Layout>

<style>
  .pricing-table-wrap {
    overflow-x: auto;
    margin-top: 2.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(13, 32, 22, 0.08);
    box-shadow: 0 4px 24px rgba(13, 32, 22, 0.06);
  }
  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    font-family: "Roboto", sans-serif;
    font-size: 0.9rem;
    background: #fff;
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .pricing-table thead tr {
    background: #1a4a2e;
    color: #fff;
  }
  .pricing-table th {
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 1rem 1.25rem;
    text-align: left;
  }
  .pricing-table tbody tr {
    border-bottom: 1px solid rgba(13, 32, 22, 0.06);
    transition: background 0.15s;
  }
  .pricing-table tbody tr:last-child {
    border-bottom: none;
  }
  .pricing-table tbody tr:hover {
    background: rgba(74, 186, 130, 0.05);
  }
  .pricing-table td {
    padding: 1rem 1.25rem;
    color: #2d4a3e;
    vertical-align: top;
  }
  .pricing-table__name {
    font-weight: 600;
    white-space: nowrap;
  }
  .pricing-table__name a {
    color: #2a7a54;
    text-decoration: none;
    transition: color 0.2s;
  }
  .pricing-table__name a:hover {
    color: #4aba82;
  }
  .pricing-table__price {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #1a4a2e;
    white-space: nowrap;
  }
  .pricing-note {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding: 1rem 1.25rem;
    background: rgba(74, 186, 130, 0.08);
    border: 1px solid rgba(74, 186, 130, 0.2);
    border-radius: 0.5rem;
    color: #1a4a2e;
    font-size: 0.875rem;
    line-height: 1.5;
  }
  .pricing-note svg {
    flex-shrink: 0;
    color: #2a7a54;
    margin-top: 0.1rem;
  }
</style>
