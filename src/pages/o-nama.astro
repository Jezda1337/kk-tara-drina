---
import Layout from "../layouts/Layout.astro";
---

<Layout title="O nama — KK Tara Drina">

  <!-- Page hero -->
  <section class="page-hero">
    <img src="https://picsum.photos/seed/about1/1920/800" alt="" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Ko smo mi</span>
      <h1 class="page-title">O nama</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <!-- Story -->
  <section class="section section--cream">
    <div class="container">
      <div class="split-layout">
        <div class="split-layout__text">
          <span class="eyebrow">Naša priča</span>
          <h2 class="section-title">Kajak kanu sportsko udruženje Tara Drina</h2>
          <p class="body-text">
            Kajak kanu sportsko udruženje Tara-Drina osnovano je 2023. godine sa jasnim ciljem —
            da ljubav prema reci i decenijsko iskustvo na vodi podelimo sa vama.
          </p>
          <p class="body-text">
            Ponosni smo na činjenicu da se u okviru našeg udruženja aktivno bavimo takmičarskim
            programom. Naš tim okuplja sve starosne kategorije, a među našim članovima su aktuelni
            reprezentativci Srbije u kajaku na divljim vodama.
          </p>
          <p class="body-text">
            Bilo da želite da savladate prve zaveslaje u našoj školi, ili tražite opuštajući spust
            niz reku sa porodicom i prijateljima, tu smo da vam pružimo vrhunsku opremu i znanje.
            Naša misija je da svaka poseta Drini postane bezbedna, edukativna i nezaboravna avantura.
          </p>
        </div>
        <div class="split-layout__media">
          <div class="img-stack">
            <img src="https://picsum.photos/seed/about2/900/700" alt="Kajak kanu sportsko udruženje Tara Drina" class="img-stack__main" />
            <div class="img-stack__secondary">
              <img src="https://picsum.photos/seed/about3/400/400" alt="Na reci Drini" />
            </div>
            <div class="img-stack__accent"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 L1440,70 L1440,70 L0,70 Z" fill="#ffffff"/>
      </svg>
    </div>
  </section>

  <!-- Osnivač -->
  <section class="section section--white">
    <div class="container">
      <div style="max-width:48rem; margin-inline:auto;">
        <span class="eyebrow" style="text-align:center;display:block;">Osnivanje</span>
        <h2 class="section-title" style="text-align:center;">Marko Marjanović</h2>
        <p class="body-text" style="text-align:center; max-width:38rem; margin-inline:auto; margin-bottom:2.5rem;">
          Osnivač udruženja je Marko Marjanović, master profesor fizičkog vaspitanja i sporta.
          Kao dugogodišnji reprezentativac Srbije, licencirani trener kajaka i spasilac na vodi,
          Marko je svoje znanje stekao na najzahtevnijim evropskim i svetskim stazama.
        </p>
        <div class="founding-grid" style="margin-top:2.5rem;">
          <div class="founding-card">
            <p class="founding-card__value">2023.</p>
            <p class="founding-card__label">Godina osnivanja</p>
            <p class="founding-card__text">Udruženje osnovano sa vizijom da ljubav prema Drini podelimo sa svima.</p>
          </div>
          <div class="founding-card">
            <p class="founding-card__value">Marko M.</p>
            <p class="founding-card__label">Osnivač kluba</p>
            <p class="founding-card__text">Master profesor fizičkog vaspitanja i sporta, licencirani trener kajaka i spasilac na vodi.</p>
          </div>
          <div class="founding-card">
            <p class="founding-card__value">Bajina Bašta</p>
            <p class="founding-card__label">Mesto osnivanja</p>
            <p class="founding-card__text">Srce Podrinja — grad koji živi uz reku Drinu već vekovima.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,80 C360,0 1080,80 1440,0 L1440,80 L0,80 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

  <!-- Vizija -->
  <section class="section section--dark-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.1)" stroke-width="0.8" fill="none">
          <path d="M-100,440 C200,405 360,448 560,415 C760,382 920,422 1120,390 C1310,362 1420,398 1540,380"/>
          <path d="M-100,405 C215,368 378,412 580,378 C780,344 940,388 1140,352 C1330,322 1432,362 1540,345"/>
          <path d="M-100,370 C232,330 395,375 600,338 C800,305 960,350 1160,312 C1350,280 1440,322 1540,305"/>
          <path d="M-100,335 C250,292 412,338 620,298 C820,262 980,310 1180,272 C1370,238 1448,282 1540,265"/>
          <path d="M-100,300 C268,254 430,302 638,260 C840,222 1000,272 1200,232 C1390,198 1455,244 1540,225"/>
          <path d="M-100,265 C285,216 448,268 658,222 C862,180 1020,235 1222,192 C1412,155 1462,205 1540,185"/>
          <path d="M-100,230 C302,178 465,235 678,185 C885,142 1042,200 1245,155 C1435,118 1468,170 1540,148"/>
        </g>
      </svg>
    </div>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow eyebrow--light">Naša vizija</span>
        <h2 class="section-title section-title--light">Čime se bavimo</h2>
      </div>
      <div class="activity-grid">
        <div class="activity-card">
          <div class="activity-card__icon">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.5l3-3 3 3 5-5 3 3"/><path stroke-linecap="round" stroke-linejoin="round" d="M3 19.5h18"/></svg>
          </div>
          <h3 class="activity-card__title">Kajak ture na Drini</h3>
          <p class="activity-card__text">Organizujemo pažljivo osmišljene ture koje spajaju uzbudljivu avanturu, potpuni mentalni mir i apsolutnu sigurnost — za sve uzraste i nivoe iskustva.</p>
          <a href="/ture/perucac-raca" class="text-link" style="color:#4aba82;margin-top:0;">Pogledaj ture →</a>
        </div>
        <div class="activity-card">
          <div class="activity-card__icon">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/></svg>
          </div>
          <h3 class="activity-card__title">Škola kajaka</h3>
          <p class="activity-card__text">Ista preciznost, disciplina i poznavanje reke koje su potrebne za vrhunske sportske rezultate, utkani su u svaki naš program obuke.</p>
          <a href="/skola-kajaka" class="text-link" style="color:#4aba82;margin-top:0;">Saznaj više →</a>
        </div>
        <div class="activity-card">
          <div class="activity-card__icon">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"/></svg>
          </div>
          <h3 class="activity-card__title">Takmičarski program</h3>
          <p class="activity-card__text">Aktivno se bavimo takmičarskim programom. Naš tim okuplja sve starosne kategorije, a među članovima su aktuelni reprezentativci Srbije u kajaku na divljim vodama.</p>
          <a href="/kontakt" class="text-link" style="color:#4aba82;margin-top:0;">Kontaktirajte nas →</a>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <!-- Lokacija -->
  <section class="section section--cta">
    <div class="container">
      <div class="split-layout">
        <div class="split-layout__text">
          <span class="eyebrow">Lokacija</span>
          <h2 class="section-title">Gde nas naći</h2>
          <p class="body-text">
            Naše glavno mesto okupljanja i baza udruženja je na izletištu Rača u Bajinoj Bašti —
            srcu Podrinja, na obali prepoznatljive tirkizne Drine.
          </p>
          <ul class="contact-info-list" style="margin-bottom:1.5rem;">
            <li class="contact-info-item">
              <span class="contact-info-item__icon">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
              </span>
              <div>
                <p class="contact-info-item__label">Adresa</p>
                <p class="contact-info-item__value">Izletište Rača, Bajina Bašta, Srbija</p>
              </div>
            </li>
            <li class="contact-info-item">
              <span class="contact-info-item__icon">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
              </span>
              <div>
                <p class="contact-info-item__label">Telefon / WhatsApp / Viber</p>
                <p class="contact-info-item__value">
                  <a href="tel:+381648969466">+381 64 896 9466</a><br/>
                  <a href="tel:+381654190939">+381 65 419 0939</a>
                </p>
              </div>
            </li>
          </ul>
          <a href="/kontakt" class="btn btn--dark">
            Kontaktirajte nas
            <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="split-layout__media">
          <img src="https://picsum.photos/seed/location1/900/700" alt="Izletište Rača, Bajina Bašta" class="split-img" />
          <div class="split-img__accent"></div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

</Layout>
