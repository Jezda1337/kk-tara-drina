---
import TourLayout from "../../../layouts/TourLayout.astro";

const gallerySlides = [
  { src: "https://picsum.photos/seed/drina2/1200/800", location: "Drina Canyon", caption: "Lorem ipsum dolor sit amet consectetur adipiscing elit" },
  { src: "https://picsum.photos/seed/drina3/1200/800", location: "Foča", caption: "Ut enim ad minim veniam quis nostrud exercitation ullamco" },
  { src: "https://picsum.photos/seed/drina4/1200/800", location: "Višegrad", caption: "Duis aute irure dolor in reprehenderit in voluptate" },
  { src: "https://picsum.photos/seed/drina5/1200/800", location: "Bajina Bašta", caption: "Excepteur sint occaecat cupidatat non proident sunt" },
  { src: "https://picsum.photos/seed/drina6/1200/800", location: "Lower river", caption: "Nemo enim ipsam voluptatem quia voluptas sit aspernatur" },
  { src: "https://picsum.photos/seed/drina7/1200/800", location: "Confluence", caption: "Sed ut perspiciatis unde omnis iste natus error sit" },
];
---

<TourLayout
  title="Drina → Sava"
  subtitle="Expedition through the heart of the Balkans"
  heroSeed="drinariver"
  distance="~55 km"
  duration="~8 hours"
  difficulty="Challenging"
  season="May – September"
  contactHref="/en/contact"
  contactLabel="Book this tour"
  gallerySlides={gallerySlides}
  equipmentLabel="Equipment included"
>
  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">About the tour</h2>
    <div class="space-y-4 leading-relaxed text-slate-600">
      <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.</p>
      <p>In voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.</p>
      <p>Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt.</p>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">Stops along the route</h2>
    <div class="space-y-4">
      {[
        { place: "Foča", time: "07:00", text: "Departure from the Foča landing. Lorem ipsum dolor sit amet consectetur adipiscing." },
        { place: "Goražde", time: "09:00", text: "Short break in town. Duis aute irure dolor in reprehenderit in voluptate velit esse." },
        { place: "Višegrad", time: "11:00", text: "Break near the Old Bridge. Excepteur sint occaecat cupidatat non proident sunt." },
        { place: "Bajina Bašta", time: "13:00", text: "Lunch and rest. Sed ut perspiciatis unde omnis iste natus error sit voluptatem." },
        { place: "Loznica", time: "14:30", text: "Last stretch before the confluence. Nemo enim ipsam voluptatem quia voluptas." },
        { place: "Confluence with Sava", time: "15:30", text: "End of the tour at the Drina–Sava confluence. At vero eos et accusamus." },
      ].map((stop) => (
        <div class="flex gap-4 rounded-xl border border-slate-100 p-5">
          <div class="flex-shrink-0"><span class="block text-xs font-bold text-teal-600">{stop.time}</span></div>
          <div>
            <h3 class="mb-1 font-bold text-slate-900">{stop.place}</h3>
            <p class="text-sm text-slate-600">{stop.text}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">What's included</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {[
        { included: true, text: "Kayak and all equipment" },
        { included: true, text: "Experienced guide" },
        { included: true, text: "Lunch by the river" },
        { included: true, text: "Transport to start" },
        { included: true, text: "Insurance" },
        { included: false, text: "Personal expenses" },
      ].map((item) => (
        <div class="flex items-center gap-3 text-sm">
          <span class:list={["flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full text-xs font-bold", item.included ? "bg-teal-100 text-teal-700" : "bg-red-50 text-red-400"]}>
            {item.included ? "✓" : "✗"}
          </span>
          <span class:list={[item.included ? "text-slate-700" : "text-slate-400"]}>{item.text}</span>
        </div>
      ))}
    </div>
  </section>
</TourLayout>
