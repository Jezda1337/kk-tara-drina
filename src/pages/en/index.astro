---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Kayak adventures on Tara and Drina" transparentNav={true}>

  <section class="hero">
    <img src="https://picsum.photos/seed/kayakriver/1920/1080" alt="" class="hero__bg" />
    <div class="hero__overlay"></div>

    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.12)" stroke-width="0.8" fill="none">
          <path d="M-100,540 C150,510 300,555 480,520 C660,485 820,530 1000,500 C1160,475 1320,510 1540,490"/>
          <path d="M-100,510 C160,475 310,522 490,485 C680,448 840,495 1020,462 C1180,435 1330,472 1540,452"/>
          <path d="M-100,480 C172,442 325,490 508,450 C698,412 858,462 1042,428 C1202,400 1345,438 1540,418"/>
          <path d="M-100,450 C185,408 340,458 528,415 C718,375 878,428 1065,392 C1225,362 1360,402 1540,382"/>
          <path d="M-100,418 C200,372 358,425 548,380 C738,338 898,395 1088,355 C1248,322 1375,368 1540,348"/>
          <path d="M-100,385 C218,336 378,392 572,344 C762,300 922,360 1115,318 C1275,282 1392,335 1540,312"/>
          <path d="M-100,352 C235,300 398,358 598,308 C792,262 952,325 1148,282 C1308,245 1408,302 1540,278"/>
          <path d="M-100,318 C252,264 418,325 622,272 C820,225 982,292 1178,246 C1338,208 1422,270 1540,244"/>
          <path d="M-100,285 C270,228 438,292 648,236 C850,188 1012,258 1210,210 C1370,172 1438,238 1540,210"/>
        </g>
      </svg>
    </div>

    <div class="hero__content">
      <p class="hero__eyebrow">Kayak Canoe Sports Association — Bajina Bašta, Serbia</p>
      <h1 class="hero__title">Discover the Drina<br /><em>from the inside</em></h1>
      <p class="hero__sub">
        The Drina river is not just water — it's a journey through pristine nature, hidden coves
        and landscapes only truly seen from a kayak. Our adventure starts here, in the heart of Bajina Bašta.
      </p>
      <div class="hero__cta">
        <a href="#tours" class="btn btn--primary">
          Explore tours
          <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/en/contact" class="btn btn--outline">Send an enquiry</a>
      </div>
    </div>

    <div class="hero__scroll-hint" aria-hidden="true">
      <svg width="20" height="28" fill="none" viewBox="0 0 20 28">
        <rect x="1" y="1" width="18" height="26" rx="9" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.4"/>
        <circle class="scroll-dot" cx="10" cy="8" r="2.5" fill="currentColor" fill-opacity="0.5"/>
      </svg>
    </div>

    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 90" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,45 C240,90 480,0 720,45 C960,90 1200,0 1440,45 L1440,90 L0,90 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section id="tours" class="section section--cream">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Our tours on the Drina</span>
        <h2 class="section-title">Choose your adventure</h2>
        <p class="section-sub">
          Whatever route you choose, your only job is to bring a good mood —
          we'll take care of everything else. Expert support, equipment and transport included.
        </p>
      </div>
      <div class="tour-grid">
        <a href="/en/tours/perucac-raca" class="tour-card group">
          <div class="tour-card__img-wrap">
            <img src="https://picsum.photos/seed/drina1/900/700" alt="Turquoise Drina below Perućac dam" class="tour-card__img"/>
            <div class="tour-card__gradient"></div>
            <div class="tour-card__badge"><span>~15 km</span><span class="badge-sep">·</span><span>~2.5h</span><span class="badge-sep">·</span><span>3,600 RSD</span></div>
            <div class="tour-card__body">
              <h3 class="tour-card__title">Perućac → Rača</h3>
              <p class="tour-card__desc">The perfect introduction to kayaking. Turquoise Drina, Vrelo waterfall and pristine Podrinje nature.</p>
              <span class="tour-card__cta">Learn more <svg class="tour-card__arrow" fill="none" viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </div>
          </div>
        </a>
        <a href="/en/tours/raca-rogacica" class="tour-card group">
          <div class="tour-card__img-wrap">
            <img src="https://picsum.photos/seed/tara2/900/700" alt="House on the Rock on the Drina" class="tour-card__img"/>
            <div class="tour-card__gradient"></div>
            <div class="tour-card__badge"><span>3–3.5h</span><span class="badge-sep">·</span><span>House on the Rock</span><span class="badge-sep">·</span><span>4,000 RSD</span></div>
            <div class="tour-card__body">
              <h3 class="tour-card__title">Rača → Rogačica</h3>
              <p class="tour-card__desc">Past the famous House on the Rock and through the Bujaković rapid — for those who want more.</p>
              <span class="tour-card__cta">Learn more <svg class="tour-card__arrow" fill="none" viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
            </div>
          </div>
        </a>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 L1440,70 L1440,70 L0,70 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

  <section class="section section--dark-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 700" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.1)" stroke-width="0.9" fill="none">
          <path d="M-100,620 C180,588 340,628 540,598 C740,568 900,608 1100,578 C1290,552 1400,582 1540,565"/>
          <path d="M-100,585 C192,550 352,592 558,560 C758,528 918,570 1118,538 C1308,510 1412,545 1540,528"/>
          <path d="M-100,550 C205,512 368,555 578,520 C778,488 938,532 1138,498 C1328,468 1425,505 1540,488"/>
          <path d="M-100,515 C218,474 385,518 598,480 C800,445 958,492 1158,455 C1348,422 1432,462 1540,445"/>
          <path d="M-100,480 C232,435 402,482 618,442 C822,405 978,455 1178,415 C1368,380 1442,422 1540,405"/>
          <path d="M-100,445 C248,396 420,445 638,402 C845,362 995,415 1198,372 C1388,332 1452,382 1540,362"/>
          <path d="M-100,408 C262,356 438,408 658,362 C868,318 1012,372 1218,325 C1408,282 1462,338 1540,318"/>
          <path d="M-100,372 C278,316 458,372 678,322 C892,275 1028,332 1238,282 C1428,235 1472,295 1540,272"/>
          <path d="M-100,335 C295,275 478,335 700,282 C918,232 1045,295 1258,242 C1448,195 1482,258 1540,235"/>
        </g>
      </svg>
    </div>
    <div class="container">
      <div class="features-header">
        <div class="features-header__left">
          <span class="eyebrow eyebrow--light">KK Tara Drina — Bajina Bašta</span>
          <h2 class="section-title section-title--light">Safety and<br/>adventure as one</h2>
          <a href="/en/about" class="btn btn--emerald" style="margin-top:1.75rem;">
            Learn more about us
            <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="features-header__right">
          <p class="features-lead">Our tours are carefully designed to combine exciting adventure, complete mental peace and absolute safety. We believe the Drina has its own pace for everyone — for those seeking calm and for those craving action.</p>
        </div>
      </div>
      <div class="feature-grid">
        <div class="feature-item"><span class="feature-item__bar"></span><div><h3 class="feature-item__title">Licensed coach & founder</h3><p class="feature-item__text">Marko Marjanović — long-time Serbian national team representative, licensed kayak coach and water rescue specialist.</p></div></div>
        <div class="feature-item"><span class="feature-item__bar"></span><div><h3 class="feature-item__title">Competitive programme</h3><p class="feature-item__text">We actively run a competitive programme — our members include current Serbian national team representatives.</p></div></div>
        <div class="feature-item"><span class="feature-item__bar"></span><div><h3 class="feature-item__title">Safety first</h3><p class="feature-item__text">Life jacket mandatory for all. The same discipline that builds champions — built into every programme.</p></div></div>
        <div class="feature-item"><span class="feature-item__bar"></span><div><h3 class="feature-item__title">Complete equipment</h3><p class="feature-item__text">Reliable kayaks, paddles and safety gear sized for each participant. Just show up and enjoy.</p></div></div>
        <div class="feature-item"><span class="feature-item__bar"></span><div><h3 class="feature-item__title">Organised transport</h3><p class="feature-item__text">Transport from base to the starting point and back. Base located at Rača picnic area, Bajina Bašta.</p></div></div>
        <div class="feature-item"><span class="feature-item__bar"></span><div><h3 class="feature-item__title">All ages welcome</h3><p class="feature-item__text">Families, couples, groups — no prior experience needed. Our guides ensure everyone gets on the water safely.</p></div></div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 110" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,110 L0,82 L36,70 L72,78 L108,55 L144,66 L180,42 L216,58 L252,34 L288,52 L324,26 L360,46 L396,20 L432,40 L468,16 L504,38 L540,12 L576,32 L612,8 L648,30 L684,14 L720,34 L756,10 L792,30 L828,6 L864,26 L900,18 L936,38 L972,14 L1008,34 L1044,20 L1080,40 L1116,26 L1152,48 L1188,34 L1224,56 L1260,44 L1296,65 L1332,52 L1368,72 L1404,60 L1440,80 L1440,110 Z" fill="#ffffff"/>
      </svg>
    </div>
  </section>

  <section class="section section--white">
    <div class="container">
      <div class="split-layout">
        <div class="split-layout__media">
          <div class="img-stack">
            <img src="https://picsum.photos/seed/club1/900/700" alt="KK Tara Drina team" class="img-stack__main"/>
            <div class="img-stack__secondary"><img src="https://picsum.photos/seed/kayak22/400/400" alt="Kayaking on the Drina"/></div>
            <div class="img-stack__accent"></div>
          </div>
        </div>
        <div class="split-layout__text">
          <span class="eyebrow">About us</span>
          <h2 class="section-title">Founded in 2023 from a love of the Drina</h2>
          <p class="body-text">Kayak Canoe Sports Association Tara-Drina was founded in 2023 with a clear goal — to share our love of the river and decades of experience on the water with you.</p>
          <p class="body-text">Our founder Marko Marjanović is a Master's degree professor, long-time Serbian national team representative and licensed coach. His vision: through expert work and maximum safety, make this sport accessible to everyone.</p>
          <a href="/en/about" class="text-link">More about the club <svg class="text-link__arrow" fill="none" viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 110" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,110 L0,88 L40,76 L80,85 L120,62 L160,74 L200,50 L240,64 L280,40 L320,56 L360,30 L400,48 L440,24 L480,44 L520,18 L560,38 L600,14 L640,34 L680,10 L720,32 L760,8 L800,28 L840,4 L880,24 L920,16 L960,36 L1000,12 L1040,32 L1080,20 L1120,40 L1160,28 L1200,50 L1240,38 L1280,60 L1320,48 L1360,70 L1400,58 L1440,78 L1440,110 Z" fill="#1a4a2e"/>
      </svg>
    </div>
  </section>

  <section class="section section--forest-topo" style="padding-bottom:10rem;">
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.14)" stroke-width="0.9" fill="none">
          <path d="M-100,540 C180,508 340,548 540,515 C740,482 900,522 1100,492 C1290,466 1400,498 1540,478"/>
          <path d="M-100,505 C192,470 352,512 558,478 C758,444 918,488 1118,455 C1308,426 1412,462 1540,442"/>
          <path d="M-100,470 C205,432 368,475 578,440 C778,406 938,450 1138,415 C1328,385 1422,422 1540,402"/>
          <path d="M-100,435 C218,394 385,440 598,402 C800,368 958,415 1158,378 C1348,348 1432,388 1540,368"/>
          <path d="M-100,400 C232,355 402,402 618,362 C822,325 978,375 1178,335 C1368,302 1442,345 1540,325"/>
          <path d="M-100,365 C248,316 420,365 638,322 C845,282 995,332 1198,290 C1388,255 1452,302 1540,282"/>
          <path d="M-100,330 C262,278 438,330 658,284 C868,242 1012,295 1218,250 C1408,210 1462,265 1540,242"/>
        </g>
      </svg>
    </div>
    <div class="container">
      <div class="split-layout split-layout--reversed">
        <div class="split-layout__text">
          <span class="eyebrow eyebrow--light">Start from zero</span>
          <h2 class="section-title section-title--light">Kayak school<br/>on the Drina</h2>
          <p class="body-text body-text--light">School led by Marko Marjanović, licensed coach and water rescue specialist. Programmes for beginners, advanced and individual sessions.</p>
          <p class="body-text body-text--light">All equipment included. School held at Rača picnic area in Bajina Bašta, on a calm and easy stretch of the Drina.</p>
          <a href="/en/kayak-school" class="btn btn--emerald" style="margin-top:0.5rem;">
            Learn more
            <svg class="btn__arrow" fill="none" viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        <div class="split-layout__media">
          <img src="https://picsum.photos/seed/school1/900/700" alt="Kayak school" class="split-img"/>
          <div class="split-img__accent split-img__accent--right"></div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 90" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,45 C360,90 1080,0 1440,45 L1440,90 L0,90 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

</Layout>

<style>
  .hero { position:relative; min-height:100svh; display:flex; align-items:center; justify-content:center; overflow:hidden; background:#0d2016; }
  .hero__bg { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:0.45; }
  .hero__overlay { position:absolute; inset:0; background:linear-gradient(to bottom,rgba(13,32,22,.3) 0%,rgba(13,32,22,.1) 40%,rgba(13,32,22,.65) 75%,#0d2016 100%); }
  .hero__content { position:relative; z-index:2; max-width:56rem; padding:6rem 1.5rem 0; text-align:center; }
  .hero__eyebrow { font-family:'Barlow Condensed',sans-serif; font-size:.72rem; font-weight:700; letter-spacing:.26em; text-transform:uppercase; color:#4aba82; margin-bottom:1.25rem; display:block; }
  .hero__title { font-family:'Barlow Condensed',sans-serif; font-size:clamp(3.5rem,10vw,7.5rem); font-weight:800; line-height:.95; letter-spacing:-.01em; color:#fff; margin-bottom:1.5rem; text-transform:uppercase; }
  .hero__title em { font-style:italic; color:#4aba82; }
  .hero__sub { font-size:1.0625rem; line-height:1.7; color:rgba(255,255,255,.72); max-width:36rem; margin:0 auto 2.5rem; }
  .hero__cta { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }
  .hero__scroll-hint { position:absolute; bottom:6.5rem; left:50%; transform:translateX(-50%); color:rgba(255,255,255,.4); animation:scrollFloat 2.5s ease-in-out infinite; z-index:2; }
  @keyframes scrollFloat { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }
  .scroll-dot { animation:scrollDot 2.5s ease-in-out infinite; }
  @keyframes scrollDot { 0%,100%{transform:translateY(0)} 50%{transform:translateY(8px)} }
  .features-header__left { display:flex; flex-direction:column; }
</style>
