---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Pravilnik — KK Tara Drina">
  <!-- Page hero -->
  <section class="page-hero">
    <img
      src="https://picsum.photos/seed/safety1/1920/800"
      alt=""
      class="page-hero__bg"
    />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Vaša bezbednost</span>
      <h1 class="page-title">Pravilnik</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg
        viewBox="0 0 1440 70"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"
        ></path>
      </svg>
    </div>
  </section>

  <!-- Rules section -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:52rem; margin-inline:auto;">
        <div class="rules-intro">
          <h2 class="section-title">
            Pravilnik o bezbednosti i ponašanju na vodi
          </h2>
          <p
            class="body-text"
            style="font-size:1.1rem; color:#0a1a12; margin-bottom:2rem;"
          >
            Vaša bezbednost je naš apsolutni prioritet. Da bi svaka tura i
            trening protekli u najboljem redu, svi učesnici aktivnosti u
            organizaciji udruženja su dužni da se pridržavaju sledećih pravila:
          </p>
        </div>

        <div class="rules-grid">
          <div class="rule-card">
            <h3 class="rule-card__title">Sigurnosna oprema</h3>
            <p class="rule-card__text">
              Obavezno korišćenje prsluka za spasavanje tokom svake aktivnosti
              na vodi. Oprema mora biti u dobrom stanju i odgovarajuće veličine.
            </p>
          </div>

          <div class="rule-card">
            <h3 class="rule-card__title">Zabranjene supstance</h3>
            <p class="rule-card__text">
              Zabranjeno je konzumiranje alkohola i drugih psihoaktivnih
              supstanci pre i tokom aktivnosti. Ovo pravilo je neprekršivo iz
              razloga bezbednosti.
            </p>
          </div>

          <div class="rule-card">
            <h3 class="rule-card__title">Zdravstvena sposobnost</h3>
            <p class="rule-card__text">
              Svaki punoletni učesnik potpisuje izjavu o preuzimanju
              odgovornosti. Za maloletne osobe, izjavu potpisuje roditelj ili
              staratelj.
            </p>
          </div>

          <div class="rule-card">
            <h3 class="rule-card__title">Ponašanje na reci</h3>
            <p class="rule-card__text">
              Pratite uputstva vodiča u svakom trenutku. Vodiči su obučeni i
              licencirani da održavaju bezbednost grupe i donete odluke su
              finalne.
            </p>
          </div>

          <div class="rule-card">
            <h3 class="rule-card__title">Odnos prema opremi</h3>
            <p class="rule-card__text">
              Namerno oštećenje opreme ili gubitak iste usled krajnje nepažnje
              podleže naknadi štete. Pazite na poverenu vam opremu.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Additional guidelines -->
  <section class="section section--cream">
    <div class="container">
      <div style="max-width:56rem; margin-inline:auto;">
        <div
          class="section-header"
          style="text-align:center; margin-bottom:3rem;"
        >
          <span class="eyebrow">Praktični saveti</span>
          <h2 class="section-title">Dodatne preporuke</h2>
        </div>

        <div class="feature-grid">
          <div class="feature-item">
            <span class="feature-item__bar"></span>
            <div>
              <h3 class="feature-item__title">Priprema pre aktivnosti</h3>
              <p class="feature-item__text">
                Dojavite sve zdravstvene probleme, dolazite u dobrom fizičkom
                stanju, pratite vremenske uslove i pazite na zaštitu od sunca.
              </p>
            </div>
          </div>

          <div class="feature-item">
            <span class="feature-item__bar"></span>
            <div>
              <h3 class="feature-item__title">Tokom aktivnosti</h3>
              <p class="feature-item__text">
                Ne ostavljajte grupu bez dozvole, obavezno nosite prsluk za
                spasavanje, pazite na ostale učesnike i javite vodiču ako imate
                problem.
              </p>
            </div>
          </div>

          <div class="feature-item">
            <span class="feature-item__bar"></span>
            <div>
              <h3 class="feature-item__title">Posle aktivnosti</h3>
              <p class="feature-item__text">
                Vratite opremu u dobrom stanju, prijavite bilo kakvu štetu,
                pratite uputstva za čuvanje i podelite povratnu informaciju.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA section -->
  <section class="section section--dark-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg
        viewBox="0 0 1440 500"
        preserveAspectRatio="xMidYMid slice"
        xmlns="http://www.w3.org/2000/svg"
      >
        <g stroke="rgba(74,186,130,0.1)" stroke-width="0.8" fill="none">
          <path
            d="M-100,440 C200,405 360,448 560,415 C760,382 920,422 1120,390 C1310,362 1420,398 1540,380"
          ></path>
          <path
            d="M-100,405 C215,368 378,412 580,378 C780,344 940,388 1140,352 C1330,322 1432,362 1540,345"
          ></path>
          <path
            d="M-100,370 C232,330 395,375 600,338 C800,305 960,350 1160,312 C1350,280 1440,322 1540,305"
          ></path>
          <path
            d="M-100,335 C250,292 412,338 620,298 C820,262 980,310 1180,272 C1370,238 1448,282 1540,265"
          ></path>
          <path
            d="M-100,300 C268,254 430,302 638,260 C840,222 1000,272 1200,232 C1390,198 1455,244 1540,225"
          ></path>
        </g>
      </svg>
    </div>
    <div class="container">
      <div style="max-width:52rem; margin-inline:auto; text-align:center;">
        <h2 class="section-title section-title--light">
          Da li ste spremni za avanturu?
        </h2>
        <p
          class="body-text"
          style="color:rgba(255,255,255,0.8); margin-bottom:2.5rem;"
        >
          Da li razumete i prihvatate sva pravila bezbednosti? Tada ste
          spremni za nezaboravnu avanturu na Drini.
        </p>
        <a href="/ture/perucac-raca" class="btn btn--primary">
          Pogledaj naše ture
          <svg
            class="btn__arrow"
            fill="none"
            viewBox="0 0 16 16"
            aria-hidden="true"
            ><path
              d="M3 8h10M9 4l4 4-4 4"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          >
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .rules-intro {
    margin-bottom: 3rem;
  }

  .rules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .rule-card {
    background: rgba(74, 186, 130, 0.06);
    border: 1px solid rgba(74, 186, 130, 0.15);
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }

  .rule-card:hover {
    background: rgba(74, 186, 130, 0.1);
    border-color: rgba(74, 186, 130, 0.3);
    transform: translateY(-2px);
  }

  .rule-card__title {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #0a1a12;
    margin-bottom: 0.75rem;
  }

  .rule-card__text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(10, 26, 18, 0.75);
  }

  .section--cream .feature-grid {
    background: transparent;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 640px) {
    .section--cream .feature-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1024px) {
    .section--cream .feature-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .section--cream .feature-item {
    padding: 2rem 2rem 2rem 1.25rem;
    border-bottom: none;
    border-left: 3px solid #4aba82;
  }

  .section--cream .feature-item__bar {
    display: none;
  }

  .section--cream .feature-item__title {
    color: #0a1a12;
  }

  .section--cream .feature-item__text {
    color: rgba(10, 26, 18, 0.7);
  }

  .btn--primary {
    background: #4aba82;
    color: #fff;
    border: 1px solid #4aba82;
    padding: 0.875rem 2rem;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 0.375rem;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .btn--primary:hover {
    background: #3a9468;
    border-color: #3a9468;
    transform: translateY(-2px);
  }

  .btn__arrow {
    width: 1rem;
    height: 1rem;
  }

  @media (max-width: 640px) {
    .rules-grid {
      grid-template-columns: 1fr;
    }

    .guideline-item__title {
      font-size: 1rem;
    }
  }
</style>
