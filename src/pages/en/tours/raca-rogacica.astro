---
import TourLayout from "../../../layouts/TourLayout.astro";

const gallerySlides = [
  {
    src: "https://picsum.photos/seed/drina_b1/1200/800",
    location: "Rača Beach",
    caption: "Starting point — Rača sandy beach on the Drina",
  },
  {
    src: "https://picsum.photos/seed/drina_b2/1200/800",
    location: "House on the Rock",
    caption: "The world-famous House on the Rock — seen only from the water",
  },
  {
    src: "https://picsum.photos/seed/drina_b3/1200/800",
    location: "Bujaković rapid",
    caption: "The adrenaline highlight — navigating through Bujaković rapid",
  },
  {
    src: "https://picsum.photos/seed/drina_b4/1200/800",
    location: "Drina — middle section",
    caption:
      "The true power of the river carrying you through unforgettable scenery",
  },
  {
    src: "https://picsum.photos/seed/drina_b5/1200/800",
    location: "Hidden beaches",
    caption: "Perfect rest stops — accessible only by paddle",
  },
  {
    src: "https://picsum.photos/seed/drina_b6/1200/800",
    location: "Rogačica",
    caption: "Tour destination — the end of an adventure you won't forget",
  },
];
---

<TourLayout
  title="Rača → Rogačica"
  subtitle="Tour 2 — Kayak tour on the Drina"
  heroSeed="drina_middle"
  distance="~20 km"
  duration="3 – 3.5 hours"
  difficulty="Moderate — House on the Rock & rapids"
  season="May – October"
  contactHref="/en/contact"
  contactLabel="Book this tour"
  gallerySlides={gallerySlides}
  equipmentLabel="Equipment included"
>
  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">About the tour</h2>
    <div class="space-y-4 leading-relaxed text-slate-600">
      <p>
        Just 2 km from the start, our adventure takes you directly past the
        world-famous
        <strong>House on the Rock</strong>. You'll have the chance to feel its
        energy up close, take incredible photographs from angles only paddlers
        can access, and learn the secret of how it stays perched on the rock.
      </p>
      <p>
        While this route is known for its beauty and tranquillity, you'll also
        feel the true power of the river here. We've saved the adrenaline
        highlight for the passage through the <strong>Bujaković rapid</strong> — an
        experience you won't forget.
      </p>
      <p>
        The route passes through landscapes best — and only truly — seen from a
        kayak. Hidden beaches along the bank are perfect for rest and swimming,
        while forests and cliffs create scenes that have shaped this region for
        centuries.
      </p>
    </div>

    <div
      class="mt-6 inline-flex items-center gap-3 rounded-xl border border-emerald-100 bg-emerald-50 px-5 py-3"
    >
      <span
        class="text-2xl font-bold text-emerald-700"
        style="font-family:'Barlow Condensed',sans-serif;">4,000 RSD</span
      >
      <span class="text-sm text-slate-500">per person · equipment included</span
      >
    </div>
  </section>

  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">Route & stops</h2>
    <div class="space-y-4">
      {
        [
          {
            place: "Rača Beach",
            time: "Departure",
            text: "Start from Rača beach. Equipment preparation and a short intro for first-time kayakers.",
          },
          {
            place: "House on the Rock",
            time: "~2 km",
            text: "Pass directly beside the famous House on the Rock. Photo stop with a perspective only paddlers get — learn the secret of its survival.",
          },
          {
            place: "Hidden beaches",
            time: "On the water",
            text: "Rest stop at one of the secluded beaches along the bank. Swimming and a break in complete natural silence.",
          },
          {
            place: "Bujaković rapid",
            time: "Adrenaline",
            text: "Tour highlight — navigating Bujaković rapid. Experience the true power of the Drina with an experienced guide by your side.",
          },
          {
            place: "Rogačica",
            time: "Finish",
            text: "Arrival in Rogačica. Refreshments and organised transport back to the base in Bajina Bašta.",
          },
        ].map((stop) => (
          <div class="flex gap-4 rounded-xl border border-slate-100 p-5">
            <div class="flex-shrink-0">
              <span class="block text-xs font-bold text-teal-600">
                {stop.time}
              </span>
            </div>
            <div>
              <h3 class="mb-1 font-bold text-slate-900">{stop.place}</h3>
              <p class="text-sm text-slate-600">{stop.text}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mb-12">
    <h2 class="mb-6 text-2xl font-bold text-slate-900">What's included</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {
        [
          { included: true, text: "Recreational kayak and paddle" },
          { included: true, text: "Life jacket" },
          { included: true, text: "Licensed guide" },
          { included: true, text: "Beginner intro (15 min)" },
          { included: true, text: "Organised transport from base" },
          { included: true, text: "Changing room and storage space" },
          { included: true, text: "Refreshments at the destination" },
          { included: false, text: "Food and personal expenses" },
        ].map((item) => (
          <div class="flex items-center gap-3 text-sm">
            <span
              class:list={[
                "flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full text-xs font-bold",
                item.included
                  ? "bg-teal-100 text-teal-700"
                  : "bg-red-50 text-red-400",
              ]}
            >
              {item.included ? "✓" : "✗"}
            </span>
            <span
              class:list={[item.included ? "text-slate-700" : "text-slate-400"]}
            >
              {item.text}
            </span>
          </div>
        ))
      }
    </div>
  </section>
</TourLayout>
