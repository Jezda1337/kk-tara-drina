---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kajak avanture na Tari i Drini" transparentNav={true}>

  <!-- ════════════════════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════════════════ -->
  <section class="hero">
    <img
      src="https://picsum.photos/seed/kayakriver/1920/1080"
      alt=""
      class="hero__bg"
    />
    <div class="hero__overlay"></div>

    <!-- Topo lines texture on hero -->
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.12)" stroke-width="0.8" fill="none">
          <path d="M-100,540 C150,510 300,555 480,520 C660,485 820,530 1000,500 C1160,475 1320,510 1540,490"/>
          <path d="M-100,515 C150,485 300,530 480,495 C660,460 820,505 1000,475 C1160,450 1320,485 1540,465"/>
          <path d="M-100,490 C160,455 310,505 490,468 C680,432 840,478 1020,448 C1180,422 1330,460 1540,438"/>
          <path d="M-100,465 C170,428 320,478 510,440 C700,404 850,452 1040,420 C1200,395 1340,432 1540,412"/>
          <path d="M-100,440 C180,400 340,452 530,412 C720,374 870,425 1060,392 C1220,365 1350,405 1540,384"/>
          <path d="M-100,412 C185,370 345,425 540,382 C735,340 888,398 1080,362 C1240,332 1365,378 1540,354"/>
          <path d="M-100,385 C190,340 355,398 555,352 C750,308 906,370 1100,332 C1260,300 1375,350 1540,324"/>
          <path d="M-100,358 C200,308 370,370 575,322 C775,278 928,342 1125,302 C1285,268 1388,322 1540,295"/>
          <path d="M-100,330 C210,278 385,342 595,292 C798,245 948,314 1148,272 C1308,238 1395,295 1540,265"/>
          <path d="M-100,302 C220,248 398,314 615,262 C820,212 968,285 1170,242 C1330,208 1402,268 1540,235"/>
          <path d="M-100,275 C235,218 412,285 635,232 C842,182 988,255 1195,212 C1352,178 1412,240 1540,208"/>
          <path d="M-100,248 C250,188 428,255 658,202 C868,152 1008,228 1222,182 C1375,148 1422,212 1540,182"/>
          <path d="M-100,220 C265,158 445,225 680,172 C895,120 1028,200 1248,152 C1398,118 1432,185 1540,155"/>
          <path d="M-100,194 C280,130 462,198 705,142 C925,90 1050,172 1275,124 C1420,90 1440,158 1540,128"/>
          <path d="M-100,168 C295,102 480,172 730,112 C955,60 1072,146 1302,96 C1438,64 1448,132 1540,102"/>
        </g>
      </svg>
    </div>

    <div class="hero__content">
      <p class="hero__eyebrow">Kajak kanu sportsko udruženje — Bajina Bašta</p>
      <h1 class="hero__title">
        Drina kakvu<br /><em>tek treba otkriti</em>
      </h1>
      <p class="hero__sub">
        Reka Drina nije samo voda — ona je put kroz netaknutu prirodu, skrivene rukavce i predele
        koji se jedino istinski vide iz kajaka. Naša avantura počinje ovde, u srcu Bajine Bašte.
      </p>
      <div class="hero__cta">
        <a href="#ture" class="btn btn--primary">
          Istraži ture
          <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/kontakt" class="btn btn--outline">
          Pošaljite upit
        </a>
      </div>
    </div>

    <div class="hero__scroll-hint" aria-hidden="true">
      <svg width="20" height="28" fill="none" viewBox="0 0 20 28">
        <rect x="1" y="1" width="18" height="26" rx="9" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.4"/>
        <circle class="scroll-dot" cx="10" cy="8" r="2.5" fill="currentColor" fill-opacity="0.5"/>
      </svg>
    </div>

    <!-- wave → cream -->
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 90" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,45 C240,90 480,0 720,45 C960,90 1200,0 1440,45 L1440,90 L0,90 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════
       TOURS — cream, full-bleed image cards
  ════════════════════════════════════════════════════════════════ -->
  <section id="ture" class="section section--cream">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Naše ture na Drini</p>
        <h2 class="section-title">Izaberite svoju avanturu</h2>
        <p class="section-sub">
          Bez obzira na to koju rutu odaberete, vaš jedini zadatak je da ponesete dobro raspoloženje —
          za sve ostalo brinemo mi. Stručna podrška, oprema i prevoz uključeni.
        </p>
      </div>

      <div class="tour-grid">
        <a href="/ture/perucac-raca" class="tour-card group">
          <div class="tour-card__img-wrap">
            <img src="https://picsum.photos/seed/drina1/900/700" alt="Tirkizna Drina ispod brane Perućac" class="tour-card__img"/>
            <div class="tour-card__gradient"></div>
            <div class="tour-card__badge">
              <span>~15 km</span><span class="badge-sep">·</span>
              <span>~2,5h</span><span class="badge-sep">·</span>
              <span>3.600 din</span>
            </div>
            <div class="tour-card__body">
              <h3 class="tour-card__title">Perućac → Rača</h3>
              <p class="tour-card__desc">Idealna ulaznica u svet kajaka. Tirkizna Drina, vodopad reke Vrelo i netaknuta priroda Podrinja.</p>
              <span class="tour-card__cta">
                Saznaj više
                <svg class="tour-card__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </div>
        </a>

        <a href="/ture/raca-rogacica" class="tour-card group">
          <div class="tour-card__img-wrap">
            <img src="https://picsum.photos/seed/tara2/900/700" alt="Kućica na steni na Drini" class="tour-card__img"/>
            <div class="tour-card__gradient"></div>
            <div class="tour-card__badge">
              <span>3–3,5h</span><span class="badge-sep">·</span>
              <span>Kućica na steni</span><span class="badge-sep">·</span>
              <span>4.000 din</span>
            </div>
            <div class="tour-card__body">
              <h3 class="tour-card__title">Rača → Rogačica</h3>
              <p class="tour-card__desc">Prolazak pored čuvene Kućice na steni i adrenalinski buk Bujakovići — za one koji žele više.</p>
              <span class="tour-card__cta">
                Saznaj više
                <svg class="tour-card__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      </div>
    </div>

    <!-- diagonal slash → dark -->
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 L1440,70 L1440,70 L0,70 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════
       WHY US — dark navy + topographic lines texture + feature grid
  ════════════════════════════════════════════════════════════════ -->
  <section class="section section--dark-topo">

    <!-- Topo lines layer -->
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 700" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.1)" stroke-width="0.9" fill="none">
          <path d="M-100,620 C180,588 340,628 540,598 C740,568 900,608 1100,578 C1290,552 1400,582 1540,565"/>
          <path d="M-100,595 C185,560 345,602 548,570 C748,540 908,582 1108,550 C1298,522 1405,558 1540,540"/>
          <path d="M-100,568 C192,530 352,576 558,542 C758,510 918,556 1118,522 C1308,492 1412,532 1540,512"/>
          <path d="M-100,540 C200,500 360,548 568,512 C768,478 928,528 1128,492 C1318,460 1418,506 1540,484"/>
          <path d="M-100,512 C208,470 370,520 580,482 C778,446 940,498 1140,460 C1330,428 1425,478 1540,455"/>
          <path d="M-100,484 C215,440 382,492 592,452 C792,414 952,468 1155,428 C1345,395 1432,450 1540,425"/>
          <path d="M-100,455 C225,408 395,462 605,420 C808,380 965,438 1168,395 C1358,360 1440,420 1540,394"/>
          <path d="M-100,425 C238,375 408,432 620,388 C825,346 978,408 1182,362 C1372,325 1448,392 1540,362"/>
          <path d="M-100,395 C250,342 425,402 638,355 C845,310 992,376 1198,328 C1388,290 1455,362 1540,330"/>
          <path d="M-100,365 C262,308 440,372 655,322 C862,275 1005,345 1215,295 C1405,255 1462,332 1540,298"/>
          <path d="M-100,335 C275,275 455,342 672,289 C882,240 1018,314 1232,262 C1422,222 1470,302 1540,268"/>
          <path d="M-100,305 C288,242 470,312 690,256 C902,205 1032,282 1250,228 C1440,188 1478,272 1540,238"/>
          <path d="M-100,275 C302,208 488,280 708,222 C922,168 1048,250 1268,195 C1458,154 1486,242 1540,208"/>
          <path d="M-100,245 C315,175 505,248 728,188 C945,132 1065,218 1288,162 C1478,120 1492,212 1540,178"/>
          <path d="M-100,215 C330,142 522,218 748,155 C968,98 1082,186 1308,128 C1495,86 1498,182 1540,148"/>
          <path d="M-100,185 C345,110 540,185 768,122 C992,65 1099,154 1328,96 C1512,55 1504,152 1540,118"/>
          <path d="M-100,158 C360,80 558,155 792,90 C1018,32 1118,124 1350,65 C1528,25 1510,122 1540,90"/>
          <path d="M-100,130 C380,52 580,128 818,60 C1045,0 1138,95 1375,36 C1542,0 1518,95 1540,65"/>
        </g>
      </svg>
    </div>

    <div class="container">
      <!-- Top split: headline left, body right -->
      <div class="features-header">
        <div class="features-header__left">
          <p class="eyebrow eyebrow--light">KK Tara Drina — Bajina Bašta</p>
          <h2 class="section-title section-title--light">Sigurnost i<br/>avantura u jednom</h2>
          <a href="/o-nama" class="btn btn--emerald" style="margin-top: 1.75rem;">
            Saznaj više o nama
            <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="features-header__right">
          <p class="features-lead">
            Naše ture su pažljivo osmišljene tako da spajaju uzbudljivu avanturu,
            potpuni mentalni mir i apsolutnu sigurnost. Verujemo da Drina ima
            svoj tempo za svakoga — i za one koji traže mir, i za one koji traže akciju.
          </p>
        </div>
      </div>

      <!-- Feature grid: 3 cols × 2 rows -->
      <div class="feature-grid">
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Licencirani trener i osnivač</h3>
            <p class="feature-item__text">Marko Marjanović — dugogodišnji reprezentativac Srbije, licencirani trener kajaka i spasilac na vodi.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Takmičarski program</h3>
            <p class="feature-item__text">Aktivno se bavimo takmičarskim programom — među članovima su aktuelni reprezentativci Srbije.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Bezbednost na prvom mestu</h3>
            <p class="feature-item__text">Prsluk za spasavanje obavezan za sve. Ista disciplina koja gradi šampione — utkana u svaki program.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Kompletna oprema</h3>
            <p class="feature-item__text">Pouzdani kajaci, vesla i sigurnosna oprema prilagođena svakom učesniku. Dolazite samo u dobrom raspoloženju.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Organizovan prevoz</h3>
            <p class="feature-item__text">Prevoz od baze do polazišta i nazad. Baza se nalazi na izletištu Rača u Bajinoj Bašti.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Za sve uzraste</h3>
            <p class="feature-item__text">Porodice, parovi, grupe — bez prethodnog iskustva. Naši vodiči su tu da svako uđe sigurno na vodu.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- mountain silhouette → white -->
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 110" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,110 L0,82 L36,70 L72,78 L108,55 L144,66 L180,42 L216,58 L252,34 L288,52 L324,26 L360,46 L396,20 L432,40 L468,16 L504,38 L540,12 L576,32 L612,8 L648,30 L684,14 L720,34 L756,10 L792,30 L828,6 L864,26 L900,18 L936,38 L972,14 L1008,34 L1044,20 L1080,40 L1116,26 L1152,48 L1188,34 L1224,56 L1260,44 L1296,65 L1332,52 L1368,72 L1404,60 L1440,80 L1440,110 Z" fill="#ffffff"/>
      </svg>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════
       ABOUT — white, overlapping image composition
  ════════════════════════════════════════════════════════════════ -->
  <section class="section section--white">
    <div class="container">
      <div class="split-layout">
        <!-- Overlapping images composition -->
        <div class="split-layout__media">
          <div class="img-stack">
            <img
              src="https://picsum.photos/seed/club1/900/700"
              alt="KK Tara Drina tim"
              class="img-stack__main"
            />
            <div class="img-stack__secondary">
              <img
                src="https://picsum.photos/seed/kayak22/400/400"
                alt="Kajakanje na Drini"
              />
            </div>
            <div class="img-stack__accent"></div>
          </div>
        </div>

        <div class="split-layout__text">
          <p class="eyebrow">O nama</p>
          <h2 class="section-title">Osnovani 2023. iz ljubavi prema Drini</h2>
          <p class="body-text">
            Kajak kanu sportsko udruženje Tara-Drina osnovano je 2023. godine sa jasnim ciljem —
            da ljubav prema reci i decenijsko iskustvo na vodi podelimo sa vama.
          </p>
          <p class="body-text">
            Naš osnivač Marko Marjanović je master profesor fizičkog vaspitanja, dugogodišnji
            reprezentativac Srbije i licencirani trener. Njegova vizija: kroz stručan rad i
            maksimalnu bezbednost svima približiti lepotu ovog sporta.
          </p>
          <a href="/o-nama" class="text-link">
            Više o klubu
            <svg class="text-link__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- mountain silhouette → pine -->
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 110" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,110 L0,88 L40,76 L80,85 L120,62 L160,74 L200,50 L240,64 L280,40 L320,56 L360,30 L400,48 L440,24 L480,44 L520,18 L560,38 L600,14 L640,34 L680,10 L720,32 L760,8 L800,28 L840,4 L880,24 L920,16 L960,36 L1000,12 L1040,32 L1080,20 L1120,40 L1160,28 L1200,50 L1240,38 L1280,60 L1320,48 L1360,70 L1400,58 L1440,78 L1440,110 Z" fill="#1a4a2e"/>
      </svg>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════
       SCHOOL — dark forest + topo lines
  ════════════════════════════════════════════════════════════════ -->
  <section class="section section--forest-topo">

    <!-- Topo lines -->
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.14)" stroke-width="0.9" fill="none">
          <path d="M-100,540 C180,508 340,548 540,515 C740,482 900,522 1100,492 C1290,466 1400,498 1540,478"/>
          <path d="M-100,510 C192,475 352,518 558,483 C758,448 918,492 1118,460 C1308,432 1412,468 1540,448"/>
          <path d="M-100,480 C205,442 368,488 578,450 C778,412 938,460 1138,426 C1328,396 1422,436 1540,415"/>
          <path d="M-100,450 C218,408 385,458 598,418 C800,378 958,428 1158,392 C1348,360 1432,404 1540,382"/>
          <path d="M-100,420 C232,375 402,428 618,385 C822,345 978,398 1178,358 C1368,325 1442,372 1540,350"/>
          <path d="M-100,390 C248,342 420,398 638,352 C845,308 995,368 1198,324 C1388,288 1452,340 1540,318"/>
          <path d="M-100,360 C262,308 438,368 658,318 C868,272 1012,338 1218,290 C1408,252 1462,308 1540,285"/>
          <path d="M-100,330 C278,275 458,338 678,285 C892,238 1028,308 1238,258 C1428,218 1472,278 1540,252"/>
          <path d="M-100,300 C295,242 478,308 700,252 C918,205 1045,278 1258,225 C1448,182 1482,248 1540,220"/>
          <path d="M-100,270 C312,208 498,278 722,218 C945,172 1062,248 1278,192 C1468,148 1492,218 1540,188"/>
          <path d="M-100,240 C330,175 518,248 745,185 C972,138 1079,218 1298,160 C1488,115 1502,188 1540,158"/>
          <path d="M-100,212 C348,142 538,218 768,152 C998,105 1096,188 1318,128 C1508,82 1512,158 1540,128"/>
        </g>
      </svg>
    </div>

    <div class="container">
      <div class="split-layout split-layout--reversed">
        <div class="split-layout__text">
          <p class="eyebrow eyebrow--light">Počnite od nule</p>
          <h2 class="section-title section-title--light">Škola kajaka<br/>na Drini</h2>
          <p class="body-text body-text--light">
            Školu vodi Marko Marjanović, licencirani trener i spasilac na vodi.
            Programi su prilagođeni rekreativnom veslanju — početnici, napredni
            ili individualni časovi.
          </p>
          <p class="body-text body-text--light">
            Sva oprema je uključena. Škola se održava na izletištu Rača u Bajinoj Bašti,
            na mirnoj i lakoj deonici Drine.
          </p>
          <a href="/skola-kajaka" class="btn btn--emerald" style="margin-top:0.5rem;">
            Saznaj više
            <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="split-layout__media">
          <img
            src="https://picsum.photos/seed/school1/900/700"
            alt="Škola kajaka"
            class="split-img"
          />
          <div class="split-img__accent split-img__accent--right"></div>
        </div>
      </div>
    </div>

    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 90" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,45 C360,90 1080,0 1440,45 L1440,90 L0,90 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>


</Layout>

<style>
  /* ─── Hero ─────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0d2016;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.45;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(13,32,22,0.3) 0%,
      rgba(13,32,22,0.1) 40%,
      rgba(13,32,22,0.65) 75%,
      #0d2016 100%
    );
  }
  .hero__content {
    position: relative;
    z-index: 2;
    max-width: 56rem;
    padding: 6rem 1.5rem 0;
    text-align: center;
  }
  .hero__eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: #4aba82;
    margin-bottom: 1.25rem;
  }
  .hero__title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(3.5rem, 10vw, 7.5rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.01em;
