---
import Layout from "../../layouts/Layout.astro";

const courses = [
  { num: "01", eyebrow: "Beginner level", title: "Beginners", duration: "Weekend course", desc: "Learn the basics of safe paddling in a controlled environment with experienced instructors. Zero prior experience is no barrier.", features: ["Paddling basics", "Water safety", "Basic steering", "Equipment included"] },
  { num: "02", eyebrow: "Intermediate level", title: "Advanced", duration: "3–4 days", desc: "Perfect for those who already know the basics and want to progress to river kayaking — rapids, current navigation and rescue techniques.", features: ["Advanced paddling", "River kayaking", "Current navigation", "Rescue skills"] },
  { num: "03", eyebrow: "Expert level", title: "Expert", duration: "5 days", desc: "For experienced kayakers who want expedition training and guide certification. Route planning and group leadership.", features: ["Expedition kayaking", "Route planning", "Guide training", "Certificate"] },
];

const skills = [
  { icon: "🚣", title: "Paddling technique", text: "Proper paddle stroke, steering in current, turning and stopping with control and efficiency." },
  { icon: "🛟", title: "Safety", text: "Capsize procedures, self-rescue, and assisting others in the water." },
  { icon: "🗺️", title: "Navigation", text: "Reading the river, assessing rapids, route planning and group management." },
  { icon: "⛺", title: "Camping", text: "Basics of camping along the river for multi-day expeditions in nature." },
];
---

<Layout title="Kayak school">

  <section class="page-hero">
    <img src="https://picsum.photos/seed/school2/1920/800" alt="" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Learn to paddle</span>
      <h1 class="page-title">Kayak school</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="split-layout">
        <div class="split-layout__text">
          <span class="eyebrow">For everyone</span>
          <h2 class="section-title">From complete beginner to expert</h2>
          <p class="body-text">No prior experience needed to get started — just the will for adventure. Our instructors are former national team members with teaching experience who know how to adapt training to every participant.</p>
          <p class="body-text">Courses for children from age 7, adults and groups of up to 12 people. All equipment is included — just show up in a swimsuit and good spirits.</p>
        </div>
        <div class="split-layout__media">
          <img src="https://picsum.photos/seed/school3/900/700" alt="Kayak school" class="split-img" />
          <div class="split-img__accent"></div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 L1440,70 L1440,70 L0,70 Z" fill="#ffffff"/>
      </svg>
    </div>
  </section>

  <section class="section section--white">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Training levels</span>
        <h2 class="section-title">Choose your level</h2>
        <p class="section-sub">We tailor the program to your experience. Contact us for information about dates and group availability.</p>
      </div>
      <div class="level-grid">
        {courses.map((c) => (
          <div class="level-card">
            <div class="level-card__num">{c.num}</div>
            <p class="level-card__eyebrow">{c.eyebrow}</p>
            <h3 class="level-card__title">{c.title}</h3>
            <p class="level-card__duration">{c.duration}</p>
            <p class="level-card__desc">{c.desc}</p>
            <ul class="level-card__features">
              {c.features.map((f) => (
                <li class="level-card__feature">
                  <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,80 C360,0 1080,80 1440,0 L1440,80 L0,80 Z" fill="#1a4a2e"/>
      </svg>
    </div>
  </section>

  <section class="section section--forest-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.12)" stroke-width="0.8" fill="none">
          <path d="M-100,430 C200,395 360,435 560,402 C760,370 920,410 1120,378 C1310,350 1420,385 1540,368"/>
          <path d="M-100,395 C215,358 378,400 580,366 C780,332 940,375 1140,340 C1330,310 1432,348 1540,330"/>
          <path d="M-100,360 C232,320 395,365 600,328 C800,295 960,338 1160,302 C1350,270 1440,310 1540,292"/>
          <path d="M-100,325 C250,282 412,328 620,290 C820,255 980,300 1180,262 C1370,228 1448,270 1540,252"/>
          <path d="M-100,290 C268,244 430,292 638,252 C840,215 1000,262 1200,222 C1390,188 1455,232 1540,212"/>
          <path d="M-100,255 C285,206 448,258 658,215 C862,175 1020,225 1222,182 C1412,145 1462,195 1540,172"/>
        </g>
      </svg>
    </div>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow eyebrow--light">Curriculum</span>
        <h2 class="section-title section-title--light">What you'll learn</h2>
      </div>
      <div class="skill-grid">
        {skills.map((s) => (
          <div class="skill-card" style="background:rgba(255,255,255,0.05);">
            <div class="skill-card__icon">{s.icon}</div>
            <h3 class="skill-card__title" style="color:#fff;">{s.title}</h3>
            <p class="skill-card__text" style="color:rgba(255,255,255,0.45);">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section class="section section--cta">
    <div class="container">
      <div class="cta-block">
        <span class="eyebrow">Interested?</span>
        <h2 class="cta-title">Sign up today</h2>
        <p class="cta-sub">Contact us for information about dates, groups and anything else you'd like to know. We respond within 24 hours.</p>
        <a href="/en/contact" class="btn btn--primary btn--large">
          Contact us
          <svg class="btn__arrow" fill="none" viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
  </section>

</Layout>
