---
interface Slide {
  src: string;
  alt?: string;
  caption?: string;
  location?: string;
}

interface Props {
  slides: Slide[];
  autoplay?: number;
}

const { slides, autoplay = 5000 } = Astro.props;
const id = `gallery-${Math.random().toString(36).slice(2, 8)}`;
const lbId = `${id}-lb`;
---

<!-- ── Gallery ─────────────────────────────────────────────────────────── -->
<section class="gallery-root" id={id} data-autoplay={autoplay} data-lb={lbId}>

  <!-- Stage -->
  <div class="stage" role="region" aria-label="Photo gallery">
    {slides.map((slide, i) => (
      <div class:list={["slide", { active: i === 0 }]} data-index={i} aria-hidden={i !== 0}>
        <button class="img-wrap" aria-label={`Open full screen: ${slide.location ?? slide.caption ?? ""}`}>
          <img src={slide.src} alt={slide.alt ?? ""} loading={i === 0 ? "eager" : "lazy"} draggable="false" />
          <span class="expand-hint" aria-hidden="true">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
            </svg>
          </span>
        </button>
        <div class="caption">
          <span class="caption-location">{slide.location ?? ""}</span>
          <p class="caption-text">{slide.caption ?? ""}</p>
        </div>
      </div>
    ))}

    <!-- Arrows -->
    <button class="arrow arrow-prev" aria-label="Previous slide">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
        <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="arrow arrow-next" aria-label="Next slide">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
        <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Counter -->
    <div class="counter" aria-live="polite" aria-atomic="true">
      <span class="counter-current">01</span>
      <span class="counter-sep">/</span>
      <span class="counter-total">{String(slides.length).padStart(2, "0")}</span>
    </div>
  </div>

  <!-- Filmstrip — desktop only -->
  <div class="filmstrip" role="tablist" aria-label="Gallery thumbnails">
    <div class="filmstrip-track">
      {slides.map((slide, i) => (
        <button class:list={["thumb", { active: i === 0 }]} role="tab"
          aria-selected={i === 0} aria-label={`Slide ${i + 1}`} data-index={i}>
          <img src={slide.src} alt="" loading="lazy" draggable="false" />
          <div class="thumb-overlay" />
        </button>
      ))}
    </div>
  </div>

  <!-- Dot indicators — mobile only -->
  <div class="dots" aria-hidden="true">
    {slides.map((_, i) => (
      <button class:list={["dot", { active: i === 0 }]} data-index={i} aria-label={`Go to slide ${i + 1}`} />
    ))}
  </div>

  <!-- Progress bar -->
  <div class="progress-bar" aria-hidden="true">
    <div class="progress-fill"></div>
  </div>
</section>

<!-- ── Lightbox ────────────────────────────────────────────────────────── -->
<div class="lightbox" id={lbId} aria-hidden="true" role="dialog" aria-modal="true" aria-label="Image viewer">
  <div class="lb-backdrop"></div>

  <button class="lb-close" aria-label="Close viewer">
    <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <div class="lb-stage">
    {slides.map((slide, i) => (
      <div class:list={["lb-slide", { active: i === 0 }]} data-index={i} aria-hidden={i !== 0}>
        <img src={slide.src} alt={slide.alt ?? ""} loading="lazy" draggable="false" />
        {(slide.location || slide.caption) && (
          <div class="lb-caption">
            {slide.location && <span class="lb-location">{slide.location}</span>}
            {slide.caption && <p class="lb-text">{slide.caption}</p>}
          </div>
        )}
      </div>
    ))}
  </div>

  <button class="lb-arrow lb-prev" aria-label="Previous image">
    <svg width="22" height="22" viewBox="0 0 20 20" fill="none">
      <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <button class="lb-arrow lb-next" aria-label="Next image">
    <svg width="22" height="22" viewBox="0 0 20 20" fill="none">
      <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="lb-counter">
    <span class="lb-counter-current">01</span>
    <span class="lb-counter-sep">/</span>
    <span class="lb-counter-total">{String(slides.length).padStart(2, "0")}</span>
  </div>
</div>

<style>
  /* ── Gallery root ── */
  .gallery-root {
    --accent: #14b8a6;
    position: relative;
    background: #050a0e;
    border-radius: 1.25rem;
    overflow: hidden;
    user-select: none;
    /* prevent gallery from ever overflowing its column */
    max-width: 100%;
    width: 100%;
  }

  /* ── Stage ── */
  .stage {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #070f14;
  }
  @media (max-width: 639px) {
    .stage { aspect-ratio: 4 / 3; }
  }

  /* ── Slides ── */
  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.7s ease;
    pointer-events: none;
  }
  .slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  /* img-wrap is now a button for click-to-open */
  .img-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: none;
    border: none;
    padding: 0;
    cursor: zoom-in;
    display: block;
    width: 100%;
    height: 100%;
  }
  .img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1);
    transition: transform 8s ease;
    will-change: transform;
    pointer-events: none;
  }
  .slide.active .img-wrap img { transform: scale(1.07); }

  /* Expand hint badge */
  .expand-hint {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: rgba(0,0,0,0.45);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.7);
    border-radius: 0.375rem;
    padding: 0.3rem 0.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }
  .img-wrap:hover .expand-hint { opacity: 1; }

  /* Dark overlays */
  .slide::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(5,10,14,0.85) 0%, rgba(5,10,14,0.1) 50%, transparent 100%),
      linear-gradient(to right, rgba(5,10,14,0.3) 0%, transparent 40%);
    pointer-events: none;
    z-index: 1;
  }
  .slide::before {
    content: "";
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 2;
  }

  /* ── Caption ── */
  .caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem 1.25rem 1rem;
    z-index: 3;
    transform: translateY(6px);
    opacity: 0;
    transition: opacity 0.5s ease 0.3s, transform 0.5s ease 0.3s;
    pointer-events: none;
  }
  .slide.active .caption { opacity: 1; transform: translateY(0); }
  .caption-location {
    display: block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.2rem;
  }
  .caption-text {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.7);
    margin: 0;
    line-height: 1.4;
  }
  @media (max-width: 639px) {
    .caption { padding: 1rem 0.875rem 0.75rem; }
    .caption-text { font-size: 0.72rem; }
  }

  /* ── Counter ── */
  .counter {
    position: absolute;
    top: 0.875rem;
    right: 1rem;
    z-index: 4;
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.5);
    pointer-events: none;
  }
  .counter-current { font-size: 0.95rem; font-weight: 700; color: #fff; }

  /* ── Arrows ── */
  .arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    color: #fff;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    backdrop-filter: blur(8px);
  }
  .arrow:hover {
    background: rgba(20,184,166,0.25);
    border-color: rgba(20,184,166,0.5);
    transform: translateY(-50%) scale(1.08);
  }
  .arrow-prev { left: 0.75rem; }
  .arrow-next { right: 0.75rem; }
  @media (max-width: 639px) {
    .arrow { width: 32px; height: 32px; }
    .arrow-prev { left: 0.5rem; }
    .arrow-next { right: 0.5rem; }
  }

  /* ── Filmstrip — hidden on mobile ── */
  .filmstrip {
    background: #06101a;
    padding: 0.5rem 0.75rem;
    overflow: hidden;
  }
  .filmstrip-track {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scrollbar-width: none;
    padding-block: 3px;
    scroll-snap-type: x mandatory;
  }
  .filmstrip-track::-webkit-scrollbar { display: none; }

  .thumb {
    flex-shrink: 0;
    width: 64px;
    height: 44px;
    border-radius: 0.3rem;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s, transform 0.2s;
    scroll-snap-align: start;
    padding: 0;
    background: none;
  }
  .thumb img { width: 100%; height: 100%; object-fit: cover; }
  .thumb-overlay {
    position: absolute;
    inset: 0;
    background: rgba(5,10,14,0.55);
    transition: opacity 0.2s;
  }
  .thumb.active { border-color: var(--accent); transform: scaleY(1.06); }
  .thumb.active .thumb-overlay { opacity: 0; }
  .thumb:hover:not(.active) .thumb-overlay { opacity: 0.2; }

  @media (max-width: 639px) {
    .filmstrip { display: none; }
  }

  /* ── Dot indicators — mobile only ── */
  .dots {
    display: none;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.6rem 0;
    background: #06101a;
  }
  @media (max-width: 639px) {
    .dots { display: flex; }
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }
  .dot.active {
    background: var(--accent);
    transform: scale(1.3);
  }

  /* ── Progress bar ── */
  .progress-bar {
    height: 2px;
    background: rgba(255,255,255,0.08);
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    width: 0%;
    background: var(--accent);
  }
  .progress-fill.running {
    transition: width linear;
  }

  /* ══════════════════════════════════════════════════════════════
     LIGHTBOX
  ══════════════════════════════════════════════════════════════ */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .lightbox.open {
    opacity: 1;
    pointer-events: auto;
  }

  .lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(3, 7, 10, 0.95);
    backdrop-filter: blur(12px);
  }

  /* Close button */
  .lb-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 10;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    backdrop-filter: blur(8px);
  }
  .lb-close:hover { background: rgba(255,255,255,0.15); color: #fff; }

  /* Stage */
  .lb-stage {
    position: relative;
    z-index: 5;
    width: 100%;
    max-width: min(90vw, 1200px);
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lb-slide {
    display: none;
    flex-direction: column;
    align-items: center;
    width: 100%;
    max-height: 90vh;
  }
  .lb-slide.active { display: flex; }

  .lb-slide img {
    max-width: 100%;
    max-height: calc(90vh - 5rem);
    object-fit: contain;
    border-radius: 0.5rem;
    display: block;
  }

  .lb-caption {
    margin-top: 0.75rem;
    text-align: center;
  }
  .lb-location {
    display: block;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.2rem;
  }
  .lb-text {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    margin: 0;
  }

  /* Lightbox arrows */
  .lb-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.07);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
    backdrop-filter: blur(8px);
  }
  .lb-arrow:hover {
    background: rgba(20,184,166,0.25);
    border-color: rgba(20,184,166,0.5);
    transform: translateY(-50%) scale(1.08);
  }
  .lb-prev { left: max(1rem, env(safe-area-inset-left)); }
  .lb-next { right: max(1rem, env(safe-area-inset-right)); }

  @media (max-width: 639px) {
    .lb-arrow { width: 38px; height: 38px; }
    .lb-prev { left: 0.5rem; }
    .lb-next { right: 0.5rem; }
    .lb-stage { max-width: 100vw; }
  }

  /* Lightbox counter */
  .lb-counter {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.4);
  }
  .lb-counter-current { font-size: 0.95rem; font-weight: 700; color: rgba(255,255,255,0.8); }
</style>

<script define:vars={{ id, lbId, autoplay }}>
  function initGallery() {
    const root = document.getElementById(id);
    const lb   = document.getElementById(lbId);
    if (!root || root.dataset.initialized) return;
    root.dataset.initialized = "true";

    /* ── Elements ── */
    const slides      = root.querySelectorAll(".slide");
    const thumbs      = root.querySelectorAll(".thumb");
    const dots        = root.querySelectorAll(".dot");
    const imgWraps    = root.querySelectorAll(".img-wrap");
    const counter     = root.querySelector(".counter-current");
    const fill        = root.querySelector(".progress-fill");
    const prevBtn     = root.querySelector(".arrow-prev");
    const nextBtn     = root.querySelector(".arrow-next");
    const filmstrip   = root.querySelector(".filmstrip-track");

    const lbSlides    = lb?.querySelectorAll(".lb-slide");
    const lbPrev      = lb?.querySelector(".lb-prev");
    const lbNext      = lb?.querySelector(".lb-next");
    const lbClose     = lb?.querySelector(".lb-close");
    const lbBackdrop  = lb?.querySelector(".lb-backdrop");
    const lbCounter   = lb?.querySelector(".lb-counter-current");

    let current  = 0;
    let timer    = null;
    let paused   = false;   // hover pause
    let lbOpen   = false;

    /* ── Gallery navigation ── */
    function goTo(index) {
      const prev = current;
      current = ((index % slides.length) + slides.length) % slides.length;

      slides[prev].classList.remove("active");
      slides[prev].setAttribute("aria-hidden", "true");
      thumbs[prev]?.classList.remove("active");
      thumbs[prev]?.setAttribute("aria-selected", "false");
      dots[prev]?.classList.remove("active");

      slides[current].classList.add("active");
      slides[current].setAttribute("aria-hidden", "false");
      thumbs[current]?.classList.add("active");
      thumbs[current]?.setAttribute("aria-selected", "true");
      dots[current]?.classList.add("active");

      if (counter) counter.textContent = String(current + 1).padStart(2, "0");

      // Scroll filmstrip to active thumb
      const activeThumb = thumbs[current];
      if (filmstrip && activeThumb) {
        const center = filmstrip.offsetWidth / 2;
        const thumbCenter = activeThumb.offsetLeft + activeThumb.offsetWidth / 2;
        filmstrip.scrollTo({ left: thumbCenter - center, behavior: "smooth" });
      }

      restartProgress();
    }

    function restartProgress() {
      if (!fill) return;
      fill.classList.remove("running");
      fill.style.width = "0%";
      fill.style.transition = "";
      if (!paused && !lbOpen) {
        requestAnimationFrame(() => requestAnimationFrame(() => {
          fill.classList.add("running");
          fill.style.transition = `width ${autoplay}ms linear`;
          fill.style.width = "100%";
        }));
      }
    }

    function startAutoplay() {
      clearInterval(timer);
      timer = setInterval(() => {
        if (!paused && !lbOpen) goTo(current + 1);
      }, autoplay);
    }

    function pauseProgress() {
      fill.style.transition = "none";
      // freeze fill at current width
      fill.style.width = fill.getBoundingClientRect().width /
        fill.parentElement.getBoundingClientRect().width * 100 + "%";
      fill.classList.remove("running");
    }

    /* ── Hover pause ── */
    root.addEventListener("mouseenter", () => {
      paused = true;
      pauseProgress();
    });
    root.addEventListener("mouseleave", () => {
      if (lbOpen) return;
      paused = false;
      restartProgress();
    });

    /* ── Arrow clicks ── */
    prevBtn?.addEventListener("click", () => { goTo(current - 1); startAutoplay(); });
    nextBtn?.addEventListener("click", () => { goTo(current + 1); startAutoplay(); });

    /* ── Thumb clicks ── */
    thumbs.forEach((thumb, i) => {
      thumb.addEventListener("click", () => { goTo(i); startAutoplay(); });
    });

    /* ── Dot clicks ── */
    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => { goTo(i); startAutoplay(); });
    });

    /* ── Keyboard (gallery) ── */
    root.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft")  { goTo(current - 1); startAutoplay(); }
      if (e.key === "ArrowRight") { goTo(current + 1); startAutoplay(); }
    });

    /* ── Touch swipe (gallery) ── */
    let touchStartX = 0;
    root.addEventListener("touchstart", (e) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    root.addEventListener("touchend", (e) => {
      const delta = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(delta) > 40) {
        goTo(delta > 0 ? current + 1 : current - 1);
        startAutoplay();
      }
    });

    /* ═══════════════════════════════
       LIGHTBOX
    ═══════════════════════════════ */
    function lbGoTo(index) {
      const prev = current;
      current = ((index % slides.length) + slides.length) % slides.length;

      lbSlides?.[prev]?.classList.remove("active");
      lbSlides?.[prev]?.setAttribute("aria-hidden", "true");
      lbSlides?.[current]?.classList.add("active");
      lbSlides?.[current]?.setAttribute("aria-hidden", "false");

      // Keep gallery in sync (no transition noise)
      slides[prev].classList.remove("active");
      slides[prev].setAttribute("aria-hidden", "true");
      thumbs[prev]?.classList.remove("active");
      dots[prev]?.classList.remove("active");
      slides[current].classList.add("active");
      slides[current].setAttribute("aria-hidden", "false");
      thumbs[current]?.classList.add("active");
      dots[current]?.classList.add("active");
      if (counter) counter.textContent = String(current + 1).padStart(2, "0");

      if (lbCounter) lbCounter.textContent = String(current + 1).padStart(2, "0");
    }

    function openLightbox(index) {
      if (!lb) return;
      lbOpen = true;
      pauseProgress();
      clearInterval(timer);

      // Sync lightbox to current index
      lbSlides?.forEach((s, i) => {
        s.classList.toggle("active", i === index);
        s.setAttribute("aria-hidden", String(i !== index));
      });
      if (lbCounter) lbCounter.textContent = String(index + 1).padStart(2, "0");
      current = index;

      lb.classList.add("open");
      lb.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
      lbClose?.focus();
    }

    function closeLightbox() {
      if (!lb) return;
      lb.classList.remove("open");
      lb.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      lbOpen = false;
      paused = false;
      restartProgress();
      startAutoplay();
    }

    /* Open on image click */
    imgWraps.forEach((wrap, i) => {
      wrap.addEventListener("click", () => openLightbox(i));
    });

    /* Lightbox controls */
    lbPrev?.addEventListener("click", () => lbGoTo(current - 1));
    lbNext?.addEventListener("click", () => lbGoTo(current + 1));
    lbClose?.addEventListener("click", closeLightbox);
    lbBackdrop?.addEventListener("click", closeLightbox);

    /* Keyboard (lightbox + global escape) */
    document.addEventListener("keydown", (e) => {
      if (!lbOpen) return;
      if (e.key === "Escape")     closeLightbox();
      if (e.key === "ArrowLeft")  lbGoTo(current - 1);
      if (e.key === "ArrowRight") lbGoTo(current + 1);
    });

    /* Touch swipe in lightbox */
    let lbTouchX = 0;
    lb?.addEventListener("touchstart", (e) => {
      lbTouchX = e.touches[0].clientX;
    }, { passive: true });
    lb?.addEventListener("touchend", (e) => {
      const delta = lbTouchX - e.changedTouches[0].clientX;
      if (Math.abs(delta) > 40) lbGoTo(delta > 0 ? current + 1 : current - 1);
    });

    /* Init */
    restartProgress();
    startAutoplay();
  }

  document.addEventListener("astro:page-load", initGallery);
  if (document.readyState !== "loading") initGallery();
  else document.addEventListener("DOMContentLoaded", initGallery);
</script>
