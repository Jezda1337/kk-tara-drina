---
import Layout from "../layouts/Layout.astro";

const includes = [
  {
    icon: `<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a4 4 0 00-5.196-3.796M9 20H4v-2a4 4 0 015.196-3.796M15 8a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
    title: "Stručna podrška",
    text: "Iskusni, licencirani vodiči prate vas tokom cele rute i brinu se o sigurnosti i informativnosti.",
  },
  {
    icon: `<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: "Oprema",
    text: "Pouzdani kajaci, lagana vesla i obavezna sigurnosna oprema prilagođena vašoj veličini.",
  },
  {
    icon: `<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>`,
    title: "Prevoz",
    text: "Organizovan prevoz od našeg centra na izletištu Rača do polazišta i nazad.",
  },
  {
    icon: `<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 22V12h6v10"/></svg>`,
    title: "Komfor",
    text: "Sigurno mesto za odlaganje ličnih stvari i prostor za presvlačenje na bazi.",
  },
  {
    icon: `<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1M4.22 4.22l.707.707m12.728 12.728l.707.707M1 12h2m18 0h2M4.22 19.78l.707-.707M18.95 5.05l.707-.707M9 12a3 3 0 106 0 3 3 0 00-6 0z"/></svg>`,
    title: "Osveženje na cilju",
    text: "Na odredištu vas čeka osveženje koje će vam povratiti energiju dok sabiramo utiske sa vode.",
  },
];
---

<Layout title="Kajak ture na Drini — KK Tara Drina">

  <!-- Page hero (standard inner-page style) -->
  <section class="page-hero">
    <img src="https://picsum.photos/seed/drina1/1920/800" alt="" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Avantura na Drini</span>
      <h1 class="page-title">Kajak ture</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <!-- Intro -->
  <section class="section section--cream">
    <div class="container">
      <div class="split-layout">
        <div class="split-layout__text">
          <span class="eyebrow">Kajak avantura</span>
          <h2 class="section-title">Šta je uključeno<br/>u svaku turu</h2>
          <p class="body-text">
            Svaka naša kajak tura pažljivo je osmišljena tako da spaja uzbudljivu avanturu,
            potpuni mentalni mir i apsolutnu sigurnost. Verujemo da Drina ima svoj tempo za
            svakoga — i za one koji traže mir, i za one koji žele akciju.
          </p>
          <p class="body-text">
            Bez obzira da li prvi put uzimate veslo u ruke ili ste iskusni na vodi, naš cilj
            je da se osećate slobodno i sigurno. Dolazite samo u dobrom raspoloženju.
          </p>
          <a href="/kontakt" class="btn btn--primary" style="margin-top: 1rem;">
            Rezervišite turu
            <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="split-layout__media">
          <img
            src="https://picsum.photos/seed/drina_kayak_guide/900/700"
            alt="Kajak tura na Drini"
            class="split-img"
          />
          <div class="split-img__accent split-img__accent--right"></div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 L1440,70 L1440,70 L0,70 Z" fill="#ffffff"/>
      </svg>
    </div>
  </section>

  <!-- Includes -->
  <section class="section section--white">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Sve na jednom mestu</span>
        <h2 class="section-title">Sva oprema i logistika — naša briga</h2>
        <p class="section-sub">Ista ona preciznost i disciplina koje su potrebne za vrhunske sportske rezultate, utkane su u svaki naš program.</p>
      </div>
      <div class="includes-feature-grid">
        {includes.map((item) => (
          <div class="includes-feature-card">
            <div class="includes-feature-card__icon" set:html={item.icon}></div>
            <h3 class="includes-feature-card__title">{item.title}</h3>
            <p class="includes-feature-card__text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,80 C360,0 1080,80 1440,0 L1440,80 L0,80 Z" fill="#1a4a2e"/>
      </svg>
    </div>
  </section>

  <!-- Tour cards -->
  <section id="ture" class="section section--forest-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.12)" stroke-width="0.8" fill="none">
          <path d="M-100,430 C200,395 360,435 560,402 C760,370 920,410 1120,378 C1310,350 1420,385 1540,368"/>
          <path d="M-100,395 C215,358 378,400 580,366 C780,332 940,375 1140,340 C1330,310 1432,348 1540,330"/>
          <path d="M-100,360 C232,320 395,365 600,328 C800,295 960,338 1160,302 C1350,270 1440,310 1540,292"/>
          <path d="M-100,325 C250,282 412,328 620,290 C820,255 980,300 1180,262 C1370,228 1448,270 1540,252"/>
          <path d="M-100,290 C268,244 430,292 638,252 C840,215 1000,262 1200,222 C1390,188 1455,232 1540,212"/>
        </g>
      </svg>
    </div>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow eyebrow--light">Naše ture na Drini</span>
        <h2 class="section-title section-title--light">Izaberite svoju avanturu</h2>
        <p class="section-sub" style="color: rgba(255,255,255,0.45);">
          Dve pažljivo osmišljene rute — od mirnijeg uvoda do adrenalinske avanture pored Kućice na steni.
        </p>
      </div>

      <div class="tour-grid">
        <a href="/ture/perucac-raca" class="tour-card group">
          <div class="tour-card__img-wrap">
            <img src="https://picsum.photos/seed/drina1/900/700" alt="Tirkizna Drina ispod brane Perućac" class="tour-card__img"/>
            <div class="tour-card__gradient"></div>
            <div class="tour-card__badge">
              <span>~15 km</span><span class="badge-sep">·</span>
              <span>~2,5h</span><span class="badge-sep">·</span>
              <span>3.600 din</span>
            </div>
            <div class="tour-card__body">
              <p class="tour-card__num">Tura 1</p>
              <h3 class="tour-card__title">Perućac → Rača</h3>
              <p class="tour-card__desc">
                Idealna ulaznica u svet kajaka. Spust tik ispod brane, pored vodopada reke Vrelo
                poznatog kao "Godina" — tirkizna Drina i netaknuta priroda Podrinja.
              </p>
              <span class="tour-card__cta">
                Saznaj više
                <svg class="tour-card__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </div>
        </a>

        <a href="/ture/raca-rogacica" class="tour-card group">
          <div class="tour-card__img-wrap">
            <img src="https://picsum.photos/seed/tara2/900/700" alt="Kućica na steni na Drini" class="tour-card__img"/>
            <div class="tour-card__gradient"></div>
            <div class="tour-card__badge">
              <span>3–3,5h</span><span class="badge-sep">·</span>
              <span>Kućica na steni</span><span class="badge-sep">·</span>
              <span>4.000 din</span>
            </div>
            <div class="tour-card__body">
              <p class="tour-card__num">Tura 2</p>
              <h3 class="tour-card__title">Rača → Rogačica</h3>
              <p class="tour-card__desc">
                Prolazak pored čuvene Kućice na steni i adrenalinski buk Bujakovići.
                Neverovatne fotografije iz uglova dostupnih isključivo veslačima.
              </p>
              <span class="tour-card__cta">
                Saznaj više
                <svg class="tour-card__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      </div>
    </div>

    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container">
      <div class="cta-block">
        <span class="eyebrow">Spremni za avanturu?</span>
        <h2 class="cta-title">Rezervišite svoje mesto</h2>
        <p class="cta-sub">Kontaktirajte nas za informacije o terminima i grupama. Nalazimo se na izletištu Rača u Bajinoj Bašti.</p>
        <a href="/kontakt" class="btn btn--primary btn--large">
          Pošaljite upit
          <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

</Layout>

<style>
  .includes-feature-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .includes-feature-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1024px) {
    .includes-feature-grid { grid-template-columns: repeat(5, 1fr); }
  }
  .includes-feature-card {
    padding: 1.75rem 1.5rem;
    border: 1px solid rgba(13,32,22,0.08);
    border-radius: 0.75rem;
    background: #fff;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .includes-feature-card:hover {
    box-shadow: 0 8px 32px rgba(13,32,22,0.1);
    transform: translateY(-2px);
  }
  .includes-feature-card__icon {
    width: 2.5rem;
    height: 2.5rem;
    background: rgba(74,186,130,0.1);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4aba82;
    margin-bottom: 1rem;
  }
  .includes-feature-card__title {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #0d2016;
    margin-bottom: 0.5rem;
  }
  .includes-feature-card__text {
    font-size: 0.85rem;
    line-height: 1.65;
    color: rgba(13,32,22,0.55);
  }

  .tour-card__num {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #4aba82;
    margin-bottom: 0.25rem;
  }
</style>
