---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Pricing — KK Tara Drina">

  <section class="page-hero">
    <img src="https://picsum.photos/seed/pricing1/1920/600" alt="" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Transparent pricing</span>
      <h1 class="page-title">Pricing</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Everything in one place</span>
        <h2 class="section-title">Our services & prices</h2>
        <p class="section-sub">
          Your only job is to bring a good mood — we'll take care of everything else.
          All equipment is included in the tour price.
        </p>
      </div>

      <div class="pricing-table-wrap">
        <table class="pricing-table">
          <thead>
            <tr>
              <th>Service</th>
              <th>Description</th>
              <th>Duration</th>
              <th>Price</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="pricing-table__name">
                <a href="/en/tours/perucac-raca">Tour 1</a>
              </td>
              <td>Descent: Perućac – Rača Picnic Area</td>
              <td>~2.5h</td>
              <td class="pricing-table__price">3,600 RSD / person</td>
            </tr>
            <tr>
              <td class="pricing-table__name">
                <a href="/en/tours/raca-rogacica">Tour 2</a>
              </td>
              <td>Descent: Rača Picnic Area – Rogačica</td>
              <td>3 – 3.5h</td>
              <td class="pricing-table__price">4,000 RSD / person</td>
            </tr>
            <tr>
              <td class="pricing-table__name">
                <a href="/en/kayak-school">Beginners' kayak school</a>
              </td>
              <td>Theory, training sessions and final river descent</td>
              <td>5 sessions + final descent</td>
              <td class="pricing-table__price">6,000 RSD</td>
            </tr>
            <tr>
              <td class="pricing-table__name">
                <a href="/en/kayak-school">Advanced kayak school</a>
              </td>
              <td>Technique work on whitewater</td>
              <td>4 sessions</td>
              <td class="pricing-table__price">5,000 RSD</td>
            </tr>
            <tr>
              <td class="pricing-table__name">
                <a href="/en/kayak-school">Individual kayak school</a>
              </td>
              <td>Fully tailored session at your level</td>
              <td>1 session (60 min)</td>
              <td class="pricing-table__price">2,500 RSD</td>
            </tr>
            <tr>
              <td class="pricing-table__name">
                <a href="/en/recreation">Recreation — membership</a>
              </td>
              <td>Use of club equipment on a monthly basis</td>
              <td>Monthly</td>
              <td class="pricing-table__price">3,000 RSD</td>
            </tr>
            <tr>
              <td class="pricing-table__name">Equipment rental</td>
              <td>Complete equipment (kayak, paddle, life jacket)</td>
              <td>By arrangement</td>
              <td class="pricing-table__price">
                1h – 600 RSD<br/>
                2h – 1,000 RSD<br/>
                3h – 1,500 RSD<br/>
                Full day – 2,000 RSD
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="pricing-note">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
        </svg>
        <p>
          For group bookings and special discounts, contact us directly.
          Payment on site — cash or card.
        </p>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 L1440,70 L1440,70 L0,70 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

  <section class="section section--dark-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 400" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.1)" stroke-width="0.8" fill="none">
          <path d="M-100,360 C180,330 360,368 560,338 C760,308 920,348 1120,318 C1310,292 1420,325 1540,308"/>
          <path d="M-100,320 C195,285 375,325 578,292 C778,260 940,302 1140,268 C1330,240 1428,278 1540,260"/>
          <path d="M-100,280 C210,242 390,285 600,250 C800,218 958,262 1160,225 C1350,195 1432,238 1540,218"/>
        </g>
      </svg>
    </div>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow eyebrow--light">Every tour includes</span>
        <h2 class="section-title section-title--light">Everything for an unforgettable experience</h2>
      </div>
      <div class="feature-grid">
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Expert support</h3>
            <p class="feature-item__text">Experienced, licensed guides who look after your safety and share their knowledge of the river.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Complete equipment</h3>
            <p class="feature-item__text">Reliable kayaks, lightweight paddles and safety equipment sized to fit you.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Organised transport</h3>
            <p class="feature-item__text">We provide organised transport from our base to the starting point and back.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Changing facilities</h3>
            <p class="feature-item__text">A secure place to store your belongings and get changed at our base before and after paddling.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Refreshments at the finish</h3>
            <p class="feature-item__text">Refreshments waiting for you at the destination to recharge while you share your impressions.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Safety first</h3>
            <p class="feature-item__text">Life jacket mandatory for all participants. Safety is our absolute priority.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section class="section section--cta">
    <div class="container">
      <div class="cta-block">
        <span class="eyebrow">Book your spot</span>
        <h2 class="cta-title">Send us an enquiry</h2>
        <p class="cta-sub">
          Contact us by phone, WhatsApp or fill in the contact form.
          We respond within 24 hours.
        </p>
        <div style="display:flex; gap:1rem; flex-wrap:wrap; justify-content:center;">
          <a href="/en/contact" class="btn btn--primary btn--large">
            Send enquiry
            <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="tel:+381648969466" class="btn btn--outline btn--large">
            Call us
          </a>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

</Layout>

<style>
  .pricing-table-wrap {
    overflow-x: auto;
    margin-top: 2.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(13, 32, 22, 0.08);
    box-shadow: 0 4px 24px rgba(13, 32, 22, 0.06);
  }
  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    font-family: "Roboto", sans-serif;
    font-size: 0.9rem;
    background: #fff;
    border-radius: 0.75rem;
    overflow: hidden;
  }
  .pricing-table thead tr { background: #1a4a2e; color: #fff; }
  .pricing-table th {
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 1rem 1.25rem;
    text-align: left;
  }
  .pricing-table tbody tr {
    border-bottom: 1px solid rgba(13, 32, 22, 0.06);
    transition: background 0.15s;
  }
  .pricing-table tbody tr:last-child { border-bottom: none; }
  .pricing-table tbody tr:hover { background: rgba(74, 186, 130, 0.05); }
  .pricing-table td { padding: 1rem 1.25rem; color: #2d4a3e; vertical-align: top; }
  .pricing-table__name { font-weight: 600; white-space: nowrap; }
  .pricing-table__name a { color: #2a7a54; text-decoration: none; transition: color 0.2s; }
  .pricing-table__name a:hover { color: #4aba82; }
  .pricing-table__price {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #1a4a2e;
    white-space: nowrap;
  }
  .pricing-note {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding: 1rem 1.25rem;
    background: rgba(74, 186, 130, 0.08);
    border: 1px solid rgba(74, 186, 130, 0.2);
    border-radius: 0.5rem;
    color: #1a4a2e;
    font-size: 0.875rem;
    line-height: 1.5;
  }
  .pricing-note svg { flex-shrink: 0; color: #2a7a54; margin-top: 0.1rem; }
</style>
