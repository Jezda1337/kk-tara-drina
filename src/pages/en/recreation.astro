---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Recreation — KK Tara Drina">

  <section class="page-hero">
    <img src="https://picsum.photos/seed/recreation1/1920/700" alt="" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">For paddling enthusiasts</span>
      <h1 class="page-title">Recreation</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="split-layout">
        <div class="split-layout__text">
          <span class="eyebrow">Free spirit on the water</span>
          <h2 class="section-title">Enjoy the Drina without a fixed schedule</h2>
          <p class="body-text">
            You've mastered the basics of paddling, feel confident in a kayak and want to enjoy
            the Drina without the strict format of a school? Our recreational section is the
            right place for you.
          </p>
          <p class="body-text">
            We offer you the opportunity to be on the water regularly, maintain your fitness
            and enjoy the company of people who share the same passion for the river and nature.
          </p>
        </div>
        <div class="split-layout__media">
          <img src="https://picsum.photos/seed/recreation2/900/700" alt="Recreational paddling on the Drina" class="split-img" />
          <div class="split-img__accent"></div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 L1440,70 L1440,70 L0,70 Z" fill="#ffffff"/>
      </svg>
    </div>
  </section>

  <section class="section section--white">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Ideal for</span>
        <h2 class="section-title">Who is recreational paddling for?</h2>
        <p class="section-sub">
          This option is open to anyone who has basic paddling skills and wants regular time on the water.
        </p>
      </div>
      <div class="feature-grid">
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Former school graduates</h3>
            <p class="feature-item__text">Completed our course and don't want to stop? Recreation is the natural continuation — keep paddling in a familiar setting.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Independent paddlers</h3>
            <p class="feature-item__text">You can paddle but don't own your own equipment? Use our kayaks, paddles and facilities as needed — no need to buy anything.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Nature lovers</h3>
            <p class="feature-item__text">Kayaking is your hobby and a way to actively unwind during the season? Join a group that shares the same passion for the Drina.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,80 C360,0 1080,80 1440,0 L1440,80 L0,80 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

  <section class="section section--dark-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 400" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.1)" stroke-width="0.8" fill="none">
          <path d="M-100,360 C180,330 360,368 560,338 C760,308 920,348 1120,318 C1310,292 1420,325 1540,308"/>
          <path d="M-100,320 C195,285 375,325 578,292 C778,260 940,302 1140,268 C1330,240 1428,278 1540,260"/>
          <path d="M-100,280 C210,242 390,285 600,250 C800,218 958,262 1160,225 C1350,195 1432,238 1540,218"/>
        </g>
      </svg>
    </div>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow eyebrow--light">Benefits</span>
        <h2 class="section-title section-title--light">What you get through the recreational programme?</h2>
      </div>
      <div class="feature-grid">
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Club equipment & space</h3>
            <p class="feature-item__text">You don't need to own a kayak. Our boats, paddles, safety equipment and changing facilities are always available to you.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Tips to improve</h3>
            <p class="feature-item__text">Although it's not a formal lesson, our team is always there to give you tips that will improve your technique and skills.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Community of paddlers</h3>
            <p class="feature-item__text">Become part of a group of enthusiasts who regularly get out on the water. Recreation is a social activity as much as a sport.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <div class="membership-block">
        <div class="membership-block__text">
          <span class="eyebrow">Become a regular member</span>
          <h2 class="section-title">Monthly membership</h2>
          <p class="body-text">
            For those who plan to be on the river regularly, we offer a monthly membership.
            This gives you regular paddling sessions during the week, plus special discounts on all our tours.
          </p>
          <ul class="membership-list">
            <li>
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Regular weekly paddling sessions
            </li>
            <li>
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Special discounts on all tours
            </li>
            <li>
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Use of club equipment and facilities
            </li>
            <li>
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Tips from a licensed instructor
            </li>
          </ul>
        </div>
        <div class="membership-block__card">
          <p class="membership-card__label">Monthly membership</p>
          <p class="membership-card__price">3,000 <span>RSD</span></p>
          <p class="membership-card__sub">per person / per month</p>
          <a href="/en/contact" class="btn btn--primary btn--large" style="width:100%; justify-content:center; margin-top:1.5rem;">
            Sign up
            <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/en/pricing" class="btn btn--outline btn--large" style="width:100%; justify-content:center; margin-top:0.75rem;">
            View all prices
          </a>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

</Layout>

<style>
  .section--white .feature-item__title,
  .section--cream .feature-item__title {
    color: #0d2016;
  }
  .section--white .feature-item__text,
  .section--cream .feature-item__text {
    color: rgba(13, 32, 22, 0.55);
  }
  .section--white .feature-item,
  .section--cream .feature-item {
    border-bottom-color: rgba(13, 32, 22, 0.06);
  }

  .membership-block {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 768px) {
    .membership-block { grid-template-columns: 1fr 360px; }
  }
  .membership-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .membership-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: #1a4a2e;
  }
  .membership-list svg { flex-shrink: 0; color: #2a7a54; }
  .membership-block__card {
    background: #1a4a2e;
    border-radius: 1rem;
    padding: 2rem;
    color: #fff;
    text-align: center;
    box-shadow: 0 20px 60px rgba(13, 32, 22, 0.25);
  }
  .membership-card__label {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.5rem;
  }
  .membership-card__price {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 4rem;
    font-weight: 800;
    line-height: 1;
    color: #4aba82;
    margin-bottom: 0.25rem;
  }
  .membership-card__price span { font-size: 1.5rem; font-weight: 600; color: rgba(255,255,255,0.6); }
  .membership-card__sub { font-size: 0.8rem; color: rgba(255,255,255,0.4); margin-bottom: 0.5rem; }
</style>
