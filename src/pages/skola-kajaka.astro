---
import Layout from "../layouts/Layout.astro";

const courses = [
  {
    num: "01",
    eyebrow: "Početnički nivo",
    title: "Škola kajaka za početnike",
    duration: "5 časova + završni spust",
    price: "6.000 din",
    desc: "Održavamo školu kajaka za početnike na Drini, na izletištu Rača. Tokom pet dana, instruktor kajaka će vas upoznati sa osnovama bezbednog veslanja na mirnim i lakim divljim vodama.",
    features: [
      "Osnovna oprema za veslanje",
      "Bezbednost na vodi",
      "Pravilno držanje vesla",
      "Upravljanje kajakom",
      "Ulaz u struju i protivstruju",
      "Završni spust niz reku",
    ],
  },
  {
    num: "02",
    eyebrow: "Napredni nivo",
    title: "Napredna škola kajaka",
    duration: "4 časa",
    price: "5.000 din",
    desc: "Namenjena je svima koji već veslaju i žele da napreduju. Posebnu pažnju posvećujemo izvođenju zahtevnijih pokreta, pravilnom ulasku u struju i protivstruju, i jačem naginjanju kajaka.",
    features: [
      "Zahtevniji pokreti i tehnike",
      "Precizan ulaz u struju",
      "Naginjanje kajaka",
      "Korišćenje rečnog toka",
      "Lokacije: Crvene vode i buk Bujaković",
    ],
  },
  {
    num: "03",
    eyebrow: "Individualni pristup",
    title: "Individualna škola kajaka",
    duration: "1 čas (60 min)",
    price: "2.500 din",
    desc: "Individualnu školu prilagođavamo vašim željama, vremenu i vašem prethodnom znanju. Tokom individualnih časova možete naučiti osnove veslanja, unaprediti znanje ili naučiti eskimotažu.",
    features: [
      "Potpuno prilagođen program",
      "Osnove ili napredne tehnike",
      "Obnova znanja",
      "Eskimotaža",
      "Fleksibilni termini",
    ],
  },
];

const skills = [
  { icon: "🚣", title: "Tehnike veslanja", text: "Pravilna tehnika zamahnute veslice, upravljanje u struji, okretanje i zaustavljanje — osnova svega." },
  { icon: "🛟", title: "Bezbednost na vodi", text: "Postupci u slučaju prevrtanja, samospasavanje, pružanje pomoći drugima i osnove spasilačkih tehnika." },
  { icon: "🗺️", title: "Navigacija rekom", text: "Čitanje reke, procena brzaka, ulaz u struju i protivstruju, planiranje rute na divljoj vodi." },
  { icon: "⛵", title: "Eskimotaža", text: "Tehnika vraćanja kajaka u uspravan položaj bez izlaska iz njega — za napredne polaznike." },
];
---

<Layout title="Škola kajaka — KK Tara Drina">

  <section class="page-hero">
    <img src="https://picsum.photos/seed/school2/1920/800" alt="" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Naučite da veslate</span>
      <h1 class="page-title">Škola kajaka</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <!-- Intro -->
  <section class="section section--cream">
    <div class="container">
      <div class="split-layout">
        <div class="split-layout__text">
          <span class="eyebrow">Stručno vodstvo</span>
          <h2 class="section-title">Školu vodi Marko Marjanović</h2>
          <p class="body-text">
            Školu kajaka vodi Marko Marjanović, dugogodišnji reprezentativac Srbije, učesnik
            svetskih i evropskih prvenstava, licencirani trener i spasilac na vodi.
          </p>
          <p class="body-text">
            Svi programi su pažljivo osmišljeni i prilagođeni rekreativnom veslanju, sa fokusom
            na bezbednost i pravilnu tehniku. Ista ona preciznost i disciplina koje su potrebne
            za vrhunske sportske rezultate, utkani su u svaki naš program.
          </p>
          <p class="body-text">
            Mi obezbeđujemo svu opremu za sve učesnike škole kajaka — kajak, veslo i prsluk za
            spasavanje. Dolazite samo u kupaćem i dobrom raspoloženju.
          </p>
        </div>
        <div class="split-layout__media">
          <img src="https://picsum.photos/seed/school3/900/700" alt="Škola kajaka na Drini" class="split-img" />
          <div class="split-img__accent"></div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 L1440,70 L1440,70 L0,70 Z" fill="#ffffff"/>
      </svg>
    </div>
  </section>

  <!-- Levels -->
  <section class="section section--white">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Nivoi obuke</span>
        <h2 class="section-title">Izaberite svoj program</h2>
        <p class="section-sub">Prilagođavamo program vašem iskustvu i ciljevima. Kontaktirajte nas za informacije o terminima i grupama.</p>
      </div>
      <div class="level-grid">
        {courses.map((c) => (
          <div class="level-card">
            <div class="level-card__num">{c.num}</div>
            <p class="level-card__eyebrow">{c.eyebrow}</p>
            <h3 class="level-card__title">{c.title}</h3>
            <p class="level-card__duration">{c.duration}</p>
            <p class="level-card__price">{c.price}</p>
            <p class="level-card__desc">{c.desc}</p>
            <ul class="level-card__features">
              {c.features.map((f) => (
                <li class="level-card__feature">
                  <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,80 C360,0 1080,80 1440,0 L1440,80 L0,80 Z" fill="#1a4a2e"/>
      </svg>
    </div>
  </section>

  <!-- Skills — dark forest + topo -->
  <section class="section section--forest-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 500" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.12)" stroke-width="0.8" fill="none">
          <path d="M-100,430 C200,395 360,435 560,402 C760,370 920,410 1120,378 C1310,350 1420,385 1540,368"/>
          <path d="M-100,395 C215,358 378,400 580,366 C780,332 940,375 1140,340 C1330,310 1432,348 1540,330"/>
          <path d="M-100,360 C232,320 395,365 600,328 C800,295 960,338 1160,302 C1350,270 1440,310 1540,292"/>
          <path d="M-100,325 C250,282 412,328 620,290 C820,255 980,300 1180,262 C1370,228 1448,270 1540,252"/>
          <path d="M-100,290 C268,244 430,292 638,252 C840,215 1000,262 1200,222 C1390,188 1455,232 1540,212"/>
          <path d="M-100,255 C285,206 448,258 658,215 C862,175 1020,225 1222,182 C1412,145 1462,195 1540,172"/>
          <path d="M-100,220 C302,168 465,225 678,178 C885,135 1042,188 1245,142 C1435,105 1468,158 1540,135"/>
        </g>
      </svg>
    </div>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow eyebrow--light">Program</span>
        <h2 class="section-title section-title--light">Šta ćete naučiti</h2>
      </div>
      <div class="skill-grid">
        {skills.map((s) => (
          <div class="skill-card" style="background:rgba(255,255,255,0.05);">
            <div class="skill-card__icon">{s.icon}</div>
            <h3 class="skill-card__title" style="color:#fff;">{s.title}</h3>
            <p class="skill-card__text" style="color:rgba(255,255,255,0.45);">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="container">
      <div class="cta-block">
        <span class="eyebrow">Zainteresovani?</span>
        <h2 class="cta-title">Prijavite se danas</h2>
        <p class="cta-sub">Kontaktirajte nas za informacije o terminima i grupama. Škola se održava na izletištu Rača u Bajinoj Bašti.</p>
        <a href="/kontakt" class="btn btn--primary btn--large">
          Kontaktirajte nas
          <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

</Layout>

<style>
  .level-card__price {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #2a7a54;
    margin-bottom: 0.75rem;
  }
</style>
