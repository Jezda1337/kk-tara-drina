---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Rekreacija — KK Tara Drina">

  <section class="page-hero">
    <img src="https://picsum.photos/seed/recreation1/1920/700" alt="" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="page-hero__content">
      <span class="eyebrow eyebrow--light">Za ljubitelje veslanja</span>
      <h1 class="page-title">Rekreacija</h1>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <!-- Intro -->
  <section class="section section--cream">
    <div class="container">
      <div class="split-layout">
        <div class="split-layout__text">
          <span class="eyebrow">Slobodan duh na vodi</span>
          <h2 class="section-title">Uživajte u Drini bez strogog rasporeda</h2>
          <p class="body-text">
            Savladali ste osnove veslanja, osećate se sigurno u kajaku i želite da uživate u Drini
            bez strogog formata škole? Naša sekcija za rekreativce je pravo mesto za vas.
          </p>
          <p class="body-text">
            Nudimo vam priliku da redovno boravite na vodi, održavate kondiciju i uživate u
            druženju sa ljudima koji dele istu strast prema reci i prirodi.
          </p>
        </div>
        <div class="split-layout__media">
          <img src="https://picsum.photos/seed/recreation2/900/700" alt="Rekreativno veslanje na Drini" class="split-img" />
          <div class="split-img__accent"></div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,0 L1440,70 L1440,70 L0,70 Z" fill="#ffffff"/>
      </svg>
    </div>
  </section>

  <!-- Kome je namenjeno -->
  <section class="section section--white">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Idealno za</span>
        <h2 class="section-title">Kome je namenjeno rekreativno veslanje?</h2>
        <p class="section-sub">
          Ova opcija je otvorena za sve koji imaju osnove veslanja i žele redovnu aktivnost na vodi.
        </p>
      </div>
      <div class="feature-grid">
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Bivši polaznici škole</h3>
            <p class="feature-item__text">Završili ste naš kurs i ne želite da stane? Rekreacija je prirodan nastavak — nastavite da veslate u poznatom okruženju.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Samostalni veslači</h3>
            <p class="feature-item__text">Znate da veslate ali nemate sopstvenu opremu? Koristite naše kajake, vesla i prostor po potrebi, bez obaveze kupovine.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Ljubitelji prirode</h3>
            <p class="feature-item__text">Kajak je vaš hobi i način za aktivno opuštanje tokom sezone? Pridružite se grupi koja deli istu strast prema Drini.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,80 C360,0 1080,80 1440,0 L1440,80 L0,80 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

  <!-- Šta dobijate -->
  <section class="section section--dark-topo">
    <div class="topo-lines" aria-hidden="true">
      <svg viewBox="0 0 1440 400" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <g stroke="rgba(74,186,130,0.1)" stroke-width="0.8" fill="none">
          <path d="M-100,360 C180,330 360,368 560,338 C760,308 920,348 1120,318 C1310,292 1420,325 1540,308"/>
          <path d="M-100,320 C195,285 375,325 578,292 C778,260 940,302 1140,268 C1330,240 1428,278 1540,260"/>
          <path d="M-100,280 C210,242 390,285 600,250 C800,218 958,262 1160,225 C1350,195 1432,238 1540,218"/>
          <path d="M-100,240 C228,198 408,245 618,208 C820,175 978,222 1182,185 C1372,152 1438,198 1540,178"/>
        </g>
      </svg>
    </div>
    <div class="container">
      <div class="section-header">
        <span class="eyebrow eyebrow--light">Benefiti</span>
        <h2 class="section-title section-title--light">Šta dobijate kroz rekreativni program?</h2>
      </div>
      <div class="feature-grid">
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Klupska oprema i prostor</h3>
            <p class="feature-item__text">Ne morate posedovati sopstveni kajak. Naši čamci, vesla i sigurnosna oprema, kao i prostor za presvlačenje i skladištenje stvari su vam uvek na raspolaganju.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Saveti za napredak</h3>
            <p class="feature-item__text">Iako nije u pitanju klasičan čas, naš tim je uvek tu da vam da savete kojima ćete unaprediti vaše veštine i tehniku veslanja.</p>
          </div>
        </div>
        <div class="feature-item">
          <span class="feature-item__bar"></span>
          <div>
            <h3 class="feature-item__title">Zajednica veslača</h3>
            <p class="feature-item__text">Postanite deo grupe entuzijasta koji redovno izlaze na vodu. Rekreacija je i društvena aktivnost, ne samo sport.</p>
          </div>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f2ede4"/>
      </svg>
    </div>
  </section>

  <!-- Članarina -->
  <section class="section section--cream">
    <div class="container">
      <div class="membership-block">
        <div class="membership-block__text">
          <span class="eyebrow">Postani stalni član</span>
          <h2 class="section-title">Mesečna članarina</h2>
          <p class="body-text">
            Za one koji planiraju da budu redovni na reci, nudimo mogućnost mesečne članarine.
            To vam omogućava redovne termine za veslanje tokom nedelje, kao i posebne popuste na sve naše ture.
          </p>
          <ul class="membership-list">
            <li>
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Redovni termini za veslanje tokom nedelje
            </li>
            <li>
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Posebni popusti na sve ture
            </li>
            <li>
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Korišćenje klupske opreme i prostora
            </li>
            <li>
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
              Saveti licenciranog instruktora
            </li>
          </ul>
        </div>
        <div class="membership-block__card">
          <p class="membership-card__label">Mesečna članarina</p>
          <p class="membership-card__price">3.000 <span>din</span></p>
          <p class="membership-card__sub">po osobi / mesečno</p>
          <a href="/kontakt" class="btn btn--primary btn--large" style="width:100%; justify-content:center; margin-top:1.5rem;">
            Prijavi se
            <svg class="btn__arrow" fill="none" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="/cenovnik" class="btn btn--outline btn--large" style="width:100%; justify-content:center; margin-top:0.75rem;">
            Pogledaj sve cene
          </a>
        </div>
      </div>
    </div>
    <div class="section-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#0a1a12"/>
      </svg>
    </div>
  </section>

</Layout>

<style>
  /* Feature items on light backgrounds need dark text */
  .section--white .feature-item__title,
  .section--cream .feature-item__title {
    color: #0d2016;
  }
  .section--white .feature-item__text,
  .section--cream .feature-item__text {
    color: rgba(13, 32, 22, 0.55);
  }
  .section--white .feature-item,
  .section--cream .feature-item {
    border-bottom-color: rgba(13, 32, 22, 0.06);
  }

  .membership-block {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 768px) {
    .membership-block {
      grid-template-columns: 1fr 360px;
    }
  }
  .membership-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .membership-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: #1a4a2e;
  }
  .membership-list svg {
    flex-shrink: 0;
    color: #2a7a54;
  }
  .membership-block__card {
    background: #1a4a2e;
    border-radius: 1rem;
    padding: 2rem;
    color: #fff;
    text-align: center;
    box-shadow: 0 20px 60px rgba(13, 32, 22, 0.25);
  }
  .membership-card__label {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.5rem;
  }
  .membership-card__price {
    font-family: "Barlow Condensed", sans-serif;
    font-size: 4rem;
    font-weight: 800;
    line-height: 1;
    color: #4aba82;
    margin-bottom: 0.25rem;
  }
  .membership-card__price span {
    font-size: 1.5rem;
    font-weight: 600;
    color: rgba(255,255,255,0.6);
  }
  .membership-card__sub {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0.5rem;
  }
</style>
